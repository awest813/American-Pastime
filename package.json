{
  "name": "vite-babylon-900",
  "description": "Babylon.js 9 and Babylon Lite Compat starter templates for Vite 8, TypeScript, React, Vue, and Svelte.",
  "author": {
    "name": "Andrei Stepanov",
    "email": "eldinor@gmail.com",
    "url": "https://babylonpress.org/"
  },
  "contributors": [
    "minibao (https://github.com/minibao/babylon-vite)"
  ],
  "private": true,
  "version": "0.2.0",
  "license": "MIT",
  "homepage": "https://babylonpress.org/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eldinor/bp900.git"
  },
  "bugs": {
    "url": "https://github.com/eldinor/bp900/issues"
  },
  "keywords": [
    "babylonjs",
    "babylon-lite",
    "lite-compat",
    "vite",
    "typescript",
    "react",
    "vue",
    "svelte",
    "template",
    "starter"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lite-compat": "node scripts/run-template.mjs dev lite-compat",
    "dev:react": "node scripts/run-template.mjs dev react",
    "dev:svelte": "node scripts/run-template.mjs dev svelte",
    "dev:vanilla": "node scripts/run-template.mjs dev vanilla",
    "dev:vue": "node scripts/run-template.mjs dev vue",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:lite-compat": "npm run typecheck && node scripts/run-template.mjs build lite-compat",
    "build:react": "npm run typecheck && node scripts/run-template.mjs build react",
    "build:svelte": "node scripts/run-template.mjs build svelte",
    "build:vanilla": "npm run typecheck && node scripts/run-template.mjs build vanilla",
    "build:vue": "node scripts/run-template.mjs build vue",
    "preview": "vite preview",
    "preview:lite-compat": "node scripts/run-template.mjs preview lite-compat",
    "preview:react": "node scripts/run-template.mjs preview react",
    "preview:svelte": "node scripts/run-template.mjs preview svelte",
    "preview:vanilla": "node scripts/run-template.mjs preview vanilla",
    "preview:vue": "node scripts/run-template.mjs preview vue"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "svelte": "^5.56.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-glsl": "^1.6.0",
    "vite-plugin-html": "^3.2.2"
  },
  "dependencies": {
    "@babylonjs/core": "^9.14.0",
    "@babylonjs/gui": "^9.14.0",
    "@babylonjs/havok": "^1.3.13",
    "@babylonjs/inspector": "^9.14.0",
    "@babylonjs/lite": "^1.6.0",
    "@babylonjs/lite-compat": "^1.6.0-preview",
    "@babylonjs/loaders": "^9.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vue": "^3.5.39"
  }
}
