{"version":3,"file":"gltf-feature-animations.js","sources":["../../../src/loader-gltf/gltf-feature-animations.ts"],"sourcesContent":["/** glTF animation feature.\n *  Triggered when the asset has any animations. Per-asset hook parses clips,\n *  binds them to the uploaded meshes, and returns AnimationGroups. */\n\nimport type { GltfFeature } from \"./gltf-feature.js\";\n\nconst feature: GltfFeature = {\n    id: \"_animations\",\n    async applyAsset(meshes, _root, ctx) {\n        const [{ parseAnimationData }, { createAnimationGroups }] = await Promise.all([import(\"./gltf-animation.js\"), import(\"../animation/animation-group.js\")]);\n        const animData = parseAnimationData(ctx._json, ctx._binChunk, meshes, ctx._parentMap, ctx._worldMatrixCache, ctx._nodeMap, ctx._boneOverrides);\n        if (!animData) {\n            return {};\n        }\n        return { animationGroups: createAnimationGroups(animData) };\n    },\n};\nexport default feature;\n"],"names":[],"mappings":"AAMA,MAAM,OAAA,GAAuB;AAAA,EACzB,EAAA,EAAI,aAAA;AAAA,EACJ,MAAM,UAAA,CAAW,MAAA,EAAQ,KAAA,EAAO,GAAA,EAAK;AACjC,IAAA,MAAM,CAAC,EAAE,kBAAA,IAAsB,EAAE,qBAAA,EAAuB,CAAA,GAAI,MAAM,OAAA,CAAQ,GAAA,CAAI,CAAC,OAAO,qBAAqB,GAAG,OAAO,iCAAiC,CAAC,CAAC,CAAA;AACxJ,IAAA,MAAM,QAAA,GAAW,kBAAA,CAAmB,GAAA,CAAI,KAAA,EAAO,IAAI,SAAA,EAAW,MAAA,EAAQ,GAAA,CAAI,UAAA,EAAY,GAAA,CAAI,iBAAA,EAAmB,GAAA,CAAI,QAAA,EAAU,IAAI,cAAc,CAAA;AAC7I,IAAA,IAAI,CAAC,QAAA,EAAU;AACX,MAAA,OAAO,EAAC;AAAA,IACZ;AACA,IAAA,OAAO,EAAE,eAAA,EAAiB,qBAAA,CAAsB,QAAQ,CAAA,EAAE;AAAA,EAC9D;AACJ;;;;"}