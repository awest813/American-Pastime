{"version":3,"file":"cross-vec3.js","sources":["../../../src/math/cross-vec3.ts"],"sourcesContent":["import type { Vec3 } from \"./types.js\";\n\n/** Compute the right-handed cross product `a x b`. */\nexport function crossVec3(a: Vec3, b: Vec3): Vec3 {\n    return {\n        x: a.y * b.z - a.z * b.y,\n        y: a.z * b.x - a.x * b.z,\n        z: a.x * b.y - a.y * b.x,\n    };\n}\n"],"names":[],"mappings":"AAGO,SAAS,SAAA,CAAU,GAAS,CAAA,EAAe;AAC9C,EAAA,OAAO;AAAA,IACH,GAAG,CAAA,CAAE,CAAA,GAAI,EAAE,CAAA,GAAI,CAAA,CAAE,IAAI,CAAA,CAAE,CAAA;AAAA,IACvB,GAAG,CAAA,CAAE,CAAA,GAAI,EAAE,CAAA,GAAI,CAAA,CAAE,IAAI,CAAA,CAAE,CAAA;AAAA,IACvB,GAAG,CAAA,CAAE,CAAA,GAAI,EAAE,CAAA,GAAI,CAAA,CAAE,IAAI,CAAA,CAAE;AAAA,GAC3B;AACJ;;;;"}