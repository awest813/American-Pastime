{"version":3,"sources":["../../../../../packages/react-resize-handle/src/hooks/useResizeHandleExample.component-browser-spec.tsx"],"sourcesContent":["import * as React from 'react';\nimport { useMergedRefs } from '@fluentui/react-components';\n\nimport { useResizeHandle, type UseResizeHandleParams } from './useResizeHandle';\n\nexport type TestAreaProps = Pick<\n  UseResizeHandleParams,\n  | 'variableTarget'\n  | 'onDragStart'\n  | 'onDragEnd'\n  | 'onChange'\n  | 'onChangeRejected'\n  | 'relative'\n  | 'minValue'\n  | 'maxValue'\n  | 'unit'\n> & { useCSSClamp?: boolean };\n\nexport function TestArea(props: TestAreaProps) {\n  const {\n    onDragEnd,\n    onDragStart,\n    onChange,\n    onChangeRejected,\n\n    minValue,\n    maxValue,\n    relative = false,\n    variableTarget = 'wrapper',\n    unit = 'px',\n    useCSSClamp = false,\n  } = props;\n\n  const codeRef = React.useRef<HTMLElement>(null);\n  const elementRef = React.useRef<HTMLDivElement>(null);\n\n  const handleChange: NonNullable<UseResizeHandleParams['onChange']> =\n    React.useCallback(\n      (ev, data) => {\n        onChange?.(ev, data);\n\n        const codeEl = codeRef.current;\n        const elementEl = elementRef.current;\n\n        if (codeEl && elementEl) {\n          const elementWidth = elementEl.getBoundingClientRect().width;\n\n          codeEl.textContent = `width (from callback): ${data.value}${data.unit}; width (actual DOM): ${elementWidth}px; eventType: ${data.type}`;\n        }\n      },\n      [onChange]\n    );\n\n  const handle = useResizeHandle({\n    growDirection: 'end',\n    relative,\n    variableName: '--width',\n    unit,\n\n    minValue,\n    maxValue,\n\n    onChange: handleChange,\n    onChangeRejected,\n    onDragEnd,\n    onDragStart,\n  });\n\n  let elementWidth = relative\n    ? `calc(50px + var(--width, 0px))`\n    : `var(--width, 50px)`;\n\n  if (relative || useCSSClamp) {\n    elementWidth = `clamp(40px, ${elementWidth}, 400px)`;\n  }\n\n  return (\n    <div\n      style={{\n        display: 'flex',\n        flexDirection: 'column',\n        gap: '12px',\n        width: '600px',\n      }}\n    >\n      {/* To have the same behavior in all browsers ⬇️ */}\n      <style>{`html, body { margin: 0; padding: 0; }`}</style>\n\n      <div\n        ref={handle.wrapperRef}\n        data-testid=\"wrapper\"\n        style={{\n          display: 'grid',\n          height: '400px',\n\n          ...(variableTarget === 'wrapper' && {\n            gridTemplateColumns: `10px ${elementWidth} 10px 1fr 10px`,\n          }),\n          ...(variableTarget === 'element' && {\n            gridTemplateColumns: '10px auto 10px 1fr 10px',\n          }),\n        }}\n      >\n        <div data-testid=\"spacer-before\" style={{ background: 'lightcyan' }} />\n        <div\n          data-testid=\"resizable\"\n          ref={useMergedRefs(handle.elementRef, elementRef)}\n          style={{\n            border: '2px dotted blue',\n            boxSizing: 'border-box',\n            height: '100%',\n\n            ...(variableTarget === 'element' && {\n              width: elementWidth,\n            }),\n          }}\n        />\n        <div\n          tabIndex={0}\n          ref={handle.handleRef}\n          role=\"separator\"\n          style={{\n            cursor: 'ew-resize',\n            backgroundColor: 'grey',\n            borderRadius: '4px',\n            boxSizing: 'border-box',\n          }}\n        />\n        <div\n          data-testid=\"static\"\n          style={{\n            border: '2px dotted green',\n            boxSizing: 'border-box',\n            height: '100%',\n          }}\n        />\n        <div data-testid=\"spacer-after\" style={{ background: 'lightcyan' }} />\n      </div>\n\n      <code\n        ref={codeRef}\n        style={{\n          padding: '4px',\n          border: '2px solid orange',\n          fontSize: 12,\n        }}\n        data-testid=\"value\"\n      >\n        Default value\n      </code>\n\n      <div>\n        <button\n          data-testid=\"reset\"\n          onClick={() => {\n            handle.setValue(relative ? 0 : 50);\n          }}\n        >\n          reset\n        </button>\n      </div>\n    </div>\n  );\n}\n"],"names":["TestArea","props","onDragEnd","onDragStart","onChange","onChangeRejected","minValue","maxValue","relative","variableTarget","unit","useCSSClamp","codeRef","React","useRef","elementRef","handleChange","useCallback","ev","data","codeEl","current","elementEl","elementWidth","getBoundingClientRect","width","textContent","value","type","handle","useResizeHandle","growDirection","variableName","div","style","display","flexDirection","gap","ref","wrapperRef","data-testid","height","gridTemplateColumns","background","useMergedRefs","border","boxSizing","tabIndex","handleRef","role","cursor","backgroundColor","borderRadius","code","padding","fontSize","button","onClick","setValue"],"mappings":";;;;+BAkBgBA;;;eAAAA;;;;iEAlBO;iCACO;iCAE8B;AAerD,SAASA,SAASC,KAAoB;IAC3C,MAAM,EACJC,SAAS,EACTC,WAAW,EACXC,QAAQ,EACRC,gBAAgB,EAEhBC,QAAQ,EACRC,QAAQ,EACRC,WAAW,KAAK,EAChBC,iBAAiB,SAAS,EAC1BC,OAAO,IAAI,EACXC,cAAc,KAAK,EACpB,GAAGV;IAEJ,MAAMW,UAAUC,OAAMC,MAAM,CAAc;IAC1C,MAAMC,aAAaF,OAAMC,MAAM,CAAiB;IAEhD,MAAME,eACJH,OAAMI,WAAW,CACf,CAACC,IAAIC;QACHf,4BAAAA,SAAWc,IAAIC;QAEf,MAAMC,SAASR,QAAQS,OAAO;QAC9B,MAAMC,YAAYP,WAAWM,OAAO;QAEpC,IAAID,UAAUE,WAAW;YACvB,MAAMC,eAAeD,UAAUE,qBAAqB,GAAGC,KAAK;YAE5DL,OAAOM,WAAW,GAAG,CAAC,uBAAuB,EAAEP,KAAKQ,KAAK,GAAGR,KAAKT,IAAI,CAAC,sBAAsB,EAAEa,aAAa,eAAe,EAAEJ,KAAKS,IAAI,EAAE;QACzI;IACF,GACA;QAACxB;KAAS;IAGd,MAAMyB,SAASC,IAAAA,gCAAe,EAAC;QAC7BC,eAAe;QACfvB;QACAwB,cAAc;QACdtB;QAEAJ;QACAC;QAEAH,UAAUY;QACVX;QACAH;QACAC;IACF;IAEA,IAAIoB,eAAef,WACf,CAAC,8BAA8B,CAAC,GAChC,CAAC,kBAAkB,CAAC;IAExB,IAAIA,YAAYG,aAAa;QAC3BY,eAAe,CAAC,YAAY,EAAEA,aAAa,QAAQ,CAAC;IACtD;IAEA,qBACE,qBAACU;QACCC,OAAO;YACLC,SAAS;YACTC,eAAe;YACfC,KAAK;YACLZ,OAAO;QACT;qBAGA,qBAACS,eAAO,CAAC,qCAAqC,CAAC,iBAE/C,qBAACD;QACCK,KAAKT,OAAOU,UAAU;QACtBC,eAAY;QACZN,OAAO;YACLC,SAA