{"version":3,"file":"gradient-block.js","sources":["../../../../../src/material/node/blocks/gradient-block.ts"],"sourcesContent":["import type { BlockEmitter } from \"../node-types.js\";\nimport { formatFloat } from \"./_math-factory.js\";\n\ninterface ColorStep {\n    readonly step: number;\n    readonly color: { readonly r: number; readonly g: number; readonly b: number };\n}\n\nfunction readSteps(raw: unknown): ColorStep[] {\n    if (!Array.isArray(raw)) {\n        return [\n            { step: 0, color: { r: 0, g: 0, b: 0 } },\n            { step: 1, color: { r: 1, g: 1, b: 1 } },\n        ];\n    }\n    return raw\n        .map((entry): ColorStep | null => {\n            if (!entry || typeof entry !== \"object\") {\n                return null;\n            }\n            const e = entry as Record<string, unknown>;\n            const c = e.color as Record<string, unknown> | undefined;\n            if (typeof e.step !== \"number\" || !c || typeof c.r !== \"number\" || typeof c.g !== \"number\" || typeof c.b !== \"number\") {\n                return null;\n            }\n            return { step: e.step, color: { r: c.r, g: c.g, b: c.b } };\n        })\n        .filter((entry): entry is ColorStep => entry !== null);\n}\n\nfunction colorLiteral(step: ColorStep): string {\n    return `vec3<f32>(${formatFloat(step.color.r)}, ${formatFloat(step.color.g)}, ${formatFloat(step.color.b)})`;\n}\n\nexport const emitter: BlockEmitter = {\n    className: \"GradientBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const input = block.inputs.get(\"gradient\");\n        const steps = readSteps(block.serialized.colorSteps);\n        if (!input?.source || steps.length === 0) {\n            return { expr: \"vec3<f32>(0.0, 0.0, 0.0)\", type: \"vec3f\" };\n        }\n        const gradient = ctx.resolve(block, \"gradient\", stage, state);\n        const g = gradient.type === \"f32\" ? gradient.expr : `((${gradient.expr}).x)`;\n        const tempColor = ctx.temp(state, \"gradientColor\");\n        const tempPosition = ctx.temp(state, \"gradientPosition\");\n        state[stage].body.push(`var ${tempColor}: vec3<f32> = ${colorLiteral(steps[0]!)};`);\n        state[stage].body.push(`var ${tempPosition}: f32;`);\n        for (let i = 1; i < steps.length; i++) {\n            const previous = steps[i - 1]!;\n            const current = steps[i]!;\n            state[stage].body.push(`${tempPosition} = clamp((${g} - ${formatFloat(previous.step)}) / (${formatFloat(current.step)} - ${formatFloat(previous.step)}), 0.0, 1.0);`);\n            state[stage].body.push(`${tempColor} = mix(${tempColor}, ${colorLiteral(current)}, ${tempPosition});`);\n        }\n        return { expr: tempColor, type: \"vec3f\" };\n    },\n};\n"],"names":[],"mappings":";;AAQA,SAAS,UAAU,GAAA,EAA2B;AAC1C,EAAA,IAAI,CAAC,KAAA,CAAM,OAAA,CAAQ,GAAG,CAAA,EAAG;AACrB,IAAA,OAAO;AAAA,MACH,EAAE,IAAA,EAAM,CAAA,EAAG,KAAA,EAAO,EAAE,CAAA,EAAG,CAAA,EAAG,CAAA,EAAG,CAAA,EAAG,CAAA,EAAG,CAAA,EAAE,EAAE;AAAA,MACvC,EAAE,IAAA,EAAM,CAAA,EAAG,KAAA,EAAO,EAAE,CAAA,EAAG,CAAA,EAAG,CAAA,EAAG,CAAA,EAAG,CAAA,EAAG,CAAA,EAAE;AAAE,KAC3C;AAAA,EACJ;AACA,EAAA,OAAO,GAAA,CACF,GAAA,CAAI,CAAC,KAAA,KAA4B;AAC9B,IAAA,IAAI,CAAC,KAAA,IAAS,OAAO,KAAA,KAAU,QAAA,EAAU;AACrC,MAAA,OAAO,IAAA;AAAA,IACX;AACA,IAAA,MAAM,CAAA,GAAI,KAAA;AACV,IAAA,MAAM,IAAI,CAAA,CAAE,KAAA;AACZ,IAAA,IAAI,OAAO,CAAA,CAAE,IAAA,KAAS,QAAA,IAAY,CAAC,KAAK,OAAO,CAAA,CAAE,CAAA,KAAM,QAAA,IAAY,OAAO,CAAA,CAAE,CAAA,KAAM,YAAY,OAAO,CAAA,CAAE,MAAM,QAAA,EAAU;AACnH,MAAA,OAAO,IAAA;AAAA,IACX;AACA,IAAA,OAAO,EAAE,IAAA,EAAM,CAAA,CAAE,IAAA,EAAM,OAAO,EAAE,CAAA,EAAG,CAAA,CAAE,CAAA,EAAG,GAAG,CAAA,CAAE,CAAA,EAAG,CAAA,EAAG,CAAA,CAAE,GAAE,EAAE;AAAA,EAC7D,CAAC,CAAA,CACA,MAAA,CAAO,CAAC,KAAA,KAA8B,UAAU,IAAI,CAAA;AAC7D;AAEA,SAAS,aAAa,IAAA,EAAyB;AAC3C,EAAA,OAAO,aAAa,WAAA,CAAY,IAAA,CAAK,KAAA,CAAM,CAAC,CAAC,CAAA,EAAA,EAAK,WAAA,CAAY,IAAA,CAAK,KAAA,CAAM,CAAC,CAAC,CAAA,EAAA,EAAK,YAAY,IAAA,CAAK,KAAA,CAAM,CAAC,CAAC,CAAA,CAAA,CAAA;AAC7G;AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,eAAA