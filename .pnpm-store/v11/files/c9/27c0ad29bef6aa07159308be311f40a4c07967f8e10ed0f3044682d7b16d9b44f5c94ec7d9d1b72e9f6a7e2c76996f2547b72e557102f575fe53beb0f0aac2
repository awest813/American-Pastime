{"version":3,"file":"color-splitter.js","sources":["../../../../../src/material/node/blocks/color-splitter.ts"],"sourcesContent":["/** ColorSplitterBlock — identical to VectorSplitter but with r/g/b/a naming. */\n\nimport type { BlockEmitter, NodeExpr, NodeValueType } from \"../node-types.js\";\n\nconst COMPONENT: Record<string, { swizzle: string; type: NodeValueType }> = {\n    rgba: { swizzle: \"\", type: \"vec4f\" },\n    rgb: { swizzle: \".xyz\", type: \"vec3f\" },\n    r: { swizzle: \".x\", type: \"f32\" },\n    g: { swizzle: \".y\", type: \"f32\" },\n    b: { swizzle: \".z\", type: \"f32\" },\n    a: { swizzle: \".w\", type: \"f32\" },\n};\n\nexport const emitter: BlockEmitter = {\n    className: \"ColorSplitterBlock\",\n    emit(block, outputName, stage, state, ctx) {\n        let source: NodeExpr | null = null;\n        for (const key of [\"rgba\", \"rgb\"] as const) {\n            if (block.inputs.get(key)?.source) {\n                source = ctx.resolve(block, key, stage, state);\n                break;\n            }\n        }\n        if (!source) {\n            throw new Error(`NodeMaterial: ColorSplitterBlock (id=${block.id}) has no connected input`);\n        }\n        const c = COMPONENT[outputName];\n        if (!c) {\n            throw new Error(`NodeMaterial: ColorSplitterBlock has no output \"${outputName}\"`);\n        }\n        return { expr: `(${source.expr})${c.swizzle}`, type: c.type };\n    },\n};\n"],"names":[],"mappings":"AAIA,MAAM,SAAA,GAAsE;AAAA,EACxE,IAAA,EAAM,EAAE,OAAA,EAAS,EAAA,EAAI,MAAM,OAAA,EAAQ;AAAA,EACnC,GAAA,EAAK,EAAE,OAAA,EAAS,MAAA,EAAQ,MAAM,OAAA,EAAQ;AAAA,EACtC,CAAA,EAAG,EAAE,OAAA,EAAS,IAAA,EAAM,MAAM,KAAA,EAAM;AAAA,EAChC,CAAA,EAAG,EAAE,OAAA,EAAS,IAAA,EAAM,MAAM,KAAA,EAAM;AAAA,EAChC,CAAA,EAAG,EAAE,OAAA,EAAS,IAAA,EAAM,MAAM,KAAA,EAAM;AAAA,EAChC,CAAA,EAAG,EAAE,OAAA,EAAS,IAAA,EAAM,MAAM,KAAA;AAC9B,CAAA;AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,oBAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,UAAA,EAAY,KAAA,EAAO,OAAO,GAAA,EAAK;AACvC,IAAA,IAAI,M