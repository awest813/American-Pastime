{"version":3,"file":"tbn-block.js","sources":["../../../../../src/material/node/blocks/tbn-block.ts"],"sourcesContent":["import type { BlockEmitter, NodeExpr } from \"../node-types.js\";\n\nfunction emitTbnRows(\n    block: Parameters<BlockEmitter[\"emit\"]>[0],\n    stage: Parameters<BlockEmitter[\"emit\"]>[2],\n    state: Parameters<BlockEmitter[\"emit\"]>[3],\n    ctx: Parameters<BlockEmitter[\"emit\"]>[4]\n): NodeExpr {\n    const stageState = stage === \"vertex\" ? state.vertex : state.fragment;\n    const memoKey = `_tbn_${block.id}`;\n    const existing = stageState.memo.get(memoKey);\n    if (existing) {\n        return existing;\n    }\n\n    const normal = ctx.cast(ctx.resolve(block, \"normal\", stage, state), \"vec3f\").expr;\n    const tangent = ctx.cast(ctx.resolve(block, \"tangent\", stage, state), \"vec4f\").expr;\n    const world = ctx.cast(ctx.resolve(block, \"world\", stage, state), \"mat4f\").expr;\n    const prefix = `_tbn${ctx.temp(state, \"tbn\")}`;\n    stageState.body.push(`let ${prefix}_normal = normalize(${normal});`);\n    stageState.body.push(`let ${prefix}_tangent = normalize((${tangent}).xyz);`);\n    stageState.body.push(`let ${prefix}_bitangent = cross(${prefix}_normal, ${prefix}_tangent) * (${tangent}).w;`);\n    stageState.body.push(\n        `let ${prefix}_mat = mat3x3<f32>((${world})[0].xyz, (${world})[1].xyz, (${world})[2].xyz) * mat3x3<f32>(${prefix}_tangent, ${prefix}_bitangent, ${prefix}_normal);`\n    );\n    stageState.body.push(`let ${prefix}_rows = vec4<f32>(${prefix}_mat[0][0], ${prefix}_mat[1][1], ${prefix}_mat[2][2], 0.0);`);\n    const result = { expr: `${prefix}_rows`, type: \"vec4f\" } as const;\n    stageState.memo.set(memoKey, result);\n    return result;\n}\n\nexport const emitter: BlockEmitter = {\n    className: \"TBNBlock\",\n    stage: \"fragment\",\n    emit(block, outputName, stage, state, ctx) {\n        if (outputName === \"TBN\") {\n            throw new Error(\"NodeMaterial: TBNBlock object output is not supported; use row0/row1/row2 outputs\");\n        }\n        const rows = emitTbnRows(block, stage, state, ctx).expr;\n        if (outputName === \"row1\") {\n            return { expr: `vec3<f32>(0.0, (${rows}).y, 0.0)`, type: \"vec3f\" };\n        }\n        if (outputName === \"row2\") {\n            return { expr: `vec3<f32>(0.0, 0.0, (${rows}).z)`, type: \"vec3f\" };\n        }\n        return { expr: `vec3<f32>((${rows}).x, 0.0, 0.0)`, type: \"vec3f\" };\n    },\n};\n"],"names":[],"mappings":"AAEA,SAAS,WAAA,CACL,KAAA,EACA,KAAA,EACA,KAAA,EACA,GAAA,EACQ;AACR,EAAA,MAAM,UAAA,GAAa,KAAA,KAAU,QAAA,GAAW,KAAA,CAAM,SAAS,KAAA,CAAM,QAAA;AAC7D,EAAA,MAAM,OAAA,GAAU,CAAA,KAAA,EAAQ,KAAA,CAAM,EAAE,CAAA,CAAA;AAChC,EAAA,MAAM,QAAA,GAAW,UAAA,CAAW,IAAA,CAAK,GAAA,CAAI,OAAO,CAAA;AAC5C,EAAA,IAAI,QAAA,EAAU;AACV,IAAA,OAAO,QAAA;AAAA,EACX;AAEA,EAAA,MAAM,MAAA,GAAS,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,QAAA,EAAU,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA,CAAE,IAAA;AAC7E,EAAA,MAAM,OAAA,GAAU,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,SAAA,EAAW,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA,CAAE,IAAA;AAC/E,EAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA,CAAE,IAAA;AAC3E,EAAA,MAAM,SAAS,CAAA,IAAA,EAAO,GAAA,CAAI,IAAA,CAAK,KAAA,EAAO,KAAK,CAAC,CAAA,CAAA;AAC5C,EAAA,UAAA,CAAW,KAAK,IAAA,CAAK,CAAA,IAAA,EAAO,MAAM,CAAA,oBAAA,EAAuB,MAAM,CAAA,EAAA,CAAI,CAAA;AACnE,EAAA,UAAA,CAAW,KAAK,IAAA,CAAK,CAAA,IAAA,EAAO,MAAM,CAAA,sBAAA,EAAyB,OAAO,CAAA,OAAA,CAAS,CAAA;AAC3E,EAAA,UAAA,CAAW,IAAA,CAAK,IAAA,CAAK,CAAA,IAAA,EAAO,MAAM,CAAA,mBAAA,EAAsB,MAAM,CAAA,SAAA,EAAY,MAAM,CAAA,aAAA,EAAgB,OAAO,CAAA,IAAA,CAAM,CAAA;AAC7G,EAAA,UAAA,CAAW,IAAA,CAAK,IAAA;AAAA,IACZ,CAAA,IAAA,EAAO,MAAM,CAAA,oBAAA,EAAuB,KAAK,CAAA,WAAA,EAAc,KAAK,CAAA,WAAA,EAAc,KAAK,CAAA,wBAAA,EAA2B,MAAM,CAAA,UAAA,EAAa,MAAM,eAAe,MAAM,CAAA,SAAA;AAAA,GAC5J;AACA,EAAA,UAAA,CAAW,IAAA,CAAK,IAAA,CAAK,CAAA,IAAA,EAAO,MAAM,CAAA,kBAAA,EAAqB,MAAM,CAAA,YAAA,EAAe,MAAM,CAAA,YAAA,EAAe,MAAM,CAAA,iBAAA,CAAmB,CAAA;AAC1H,EA