{"version":3,"file":"replace-color-block.js","sources":["../../../../../src/material/node/blocks/replace-color-block.ts"],"sourcesContent":["import type { BlockEmitter } from \"../node-types.js\";\n\nexport const emitter: BlockEmitter = {\n    className: \"ReplaceColorBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const value = ctx.resolve(block, \"value\", stage, state);\n        if (value.type === \"f32\" || value.type === \"mat4f\" || value.type === \"texture2d\" || value.type === \"textureCube\") {\n            throw new Error(`NodeMaterial: ReplaceColorBlock requires a vector/color value; got ${value.type}`);\n        }\n        const reference = ctx.cast(ctx.resolve(block, \"reference\", stage, state), value.type).expr;\n        const distance = ctx.cast(ctx.resolve(block, \"distance\", stage, state), \"f32\").expr;\n        const replacement = ctx.cast(ctx.resolve(block, \"replacement\", stage, state), value.type).expr;\n        return { expr: `select(${value.expr}, ${replacement}, length(${value.expr} - ${reference}) < ${distance})`, type: value.type };\n    },\n};\n"],"names":[],"mappings":"AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,mBAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,QAAQ,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,OAAO,KAAK,CAAA;AACtD,IAAA,IAAI,KAAA,CAAM,IAAA,KAAS,KAAA,IAAS,KAAA,CAAM,IAAA,KAAS,OAAA,IAAW,KAAA,CAAM,IAAA,KAAS,WAAA,IAAe,KAAA,CAAM,IAAA,KAAS,aAAA,EAAe;AAC9G,MAAA,MAAM,IAAI,KAAA,CAAM,CAAA,mEAAA,EAAsE,KAAA,CAAM,IAAI,CAAA,CAAE,CAAA;AAAA,IACtG;AACA,IAAA,MAAM,SAAA,GAAY,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,KAAK,CAAA,EAAG,KAAA,CAAM,IAAI,CAAA,CAAE,IAAA;AACtF,IAAA,MAAM,QAAA,GAAW,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,UAAA,EAAY,KAAA,EAAO,KAAK,CAAA,EAAG,KAAK,CAAA,CAAE,IAAA;AAC/E,IAAA,MAAM,WAAA,GAAc,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,aAAA,EAAe,KAAA,EAAO,KAAK,CAAA,EAAG,KAAA,CAAM,IAAI,CAAA,CAAE,IAAA;AAC1F,IAAA,OAAO,EAAE,IAAA,EAAM,CAAA