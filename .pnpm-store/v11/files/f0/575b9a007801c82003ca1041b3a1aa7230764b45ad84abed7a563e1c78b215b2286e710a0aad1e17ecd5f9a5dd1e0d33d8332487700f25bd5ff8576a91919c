{"version":3,"file":"node-snippet.js","sources":["../../../../src/material/node/node-snippet.ts"],"sourcesContent":["const DEFAULT_SNIPPET_SERVER = \"https://snippet.babylonjs.com\";\n\nexport async function fetchSnippetSource(snippetId: string, server: string = DEFAULT_SNIPPET_SERVER): Promise<unknown> {\n    const [id, version] = snippetId.split(\"#\");\n    const url = version ? `${server}/${id}/${version}` : `${server}/${id}`;\n    const resp = await fetch(url);\n    if (!resp.ok) {\n        throw new Error(`NodeMaterial: snippet fetch failed (${resp.status}) for ${url}`);\n    }\n    const outer = (await resp.json()) as { jsonPayload?: string };\n    if (!outer.jsonPayload) {\n        throw new Error(`NodeMaterial: snippet \"${snippetId}\" has no jsonPayload`);\n    }\n    const inner = JSON.parse(outer.jsonPayload) as { nodeMaterial?: string };\n    if (!inner.nodeMaterial) {\n        throw new Error(`NodeMaterial: snippet \"${snippetId}\" has no nodeMaterial`);\n    }\n    return JSON.parse(inner.nodeMaterial);\n}\n"],"names":[],"mappings":"AAAA,MAAM,sBAAA,GAAyB,+BAAA;AAE/B,eAAsB,kBAAA,CAAmB,SAAA,EAAmB,MAAA,GAAiB,sBAAA,EAA0C;AACnH,EAAA,MAAM,CAAC,EAAA,EAAI,OAAO,CAAA,GAAI,SAAA,CAAU,MAAM,GAAG,CAAA;AACzC,EAAA,MAAM,GAAA,GAAM,OAAA,GAAU,CAAA,EAAG,MAAM,CAAA,CAAA,EAAI,EAAE,CAAA,CAAA,EAAI,OAAO,CAAA,CAAA,GAAK,CAAA,EAAG,MAAM,CAAA,CAAA,EAAI,EAAE,CAAA,CAAA;AACpE,EAAA,MAAM,IAAA,GAAO,MAAM,KAAA,CAAM,GAAG,CAAA;AAC5B,EAAA,IAAI,CAAC,KAAK,EAAA,EAAI;AACV,IAAA,MAAM,IAAI,KAAA,CAAM,CAAA,oCAAA,EAAuC,KAAK,MAAM,CAAA,MAAA,EAAS,GAAG,CAAA,CAAE,CAAA;AAAA,EACpF;AACA,EAAA,MAAM,KAAA,GAAS,MAAM,IAAA,CAAK,IAAA,EAAK;AAC/B,EAAA,IAAI,CAAC,MAAM,WAAA,EAAa;AACpB,IAAA,MAAM,IAAI,KAAA,CAAM,CAAA,uBAAA,EAA0B,SAAS,CAAA,oBAAA,CAAsB,CAAA;AAAA,EAC7E;AACA,EAAA,MAAM,KAAA,GAAQ,IAAA,CAAK,KAAA,CAAM,KAAA,CAAM,WAAW,CAAA;AAC1C,EAAA,IAAI,CAAC,MAAM,YAAA,EAAc;AACrB,IAAA,MAAM,IAAI,KAAA,CAAM,CAAA,uBAAA,EAA0B,SAAS,CAAA,qBAAA,CAAuB,CAAA;AAAA,EAC9E;AACA,EAAA,OAAO,IAAA,CAAK,KAAA,CAAM,KAAA,CAAM,YAAY,CAAA;AACxC;;;;"}