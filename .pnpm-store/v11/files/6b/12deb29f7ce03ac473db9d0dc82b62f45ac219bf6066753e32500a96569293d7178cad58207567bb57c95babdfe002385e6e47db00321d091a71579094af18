{"version":3,"file":"derivative-block.js","sources":["../../../../../src/material/node/blocks/derivative-block.ts"],"sourcesContent":["import type { BlockEmitter } from \"../node-types.js\";\n\nconst OUTPUT_FN: Record<string, string> = {\n    dx: \"dpdx\",\n    dy: \"dpdy\",\n};\n\nexport const emitter: BlockEmitter = {\n    className: \"DerivativeBlock\",\n    stage: \"fragment\",\n    emit(block, outputName, stage, state, ctx) {\n        const fn = OUTPUT_FN[outputName];\n        if (!fn) {\n            throw new Error(`NodeMaterial: DerivativeBlock output \"${outputName}\" is not supported`);\n        }\n        const input = ctx.resolve(block, \"input\", stage, state);\n        return { expr: `${fn}(${input.expr})`, type: input.type };\n    },\n};\n"],"names":[],"mappings":"AAEA,MAAM,SAAA,GAAoC;AAAA,EACtC,EAAA,EAAI,MAAA;AAAA,EACJ,EAAA,EAAI;AACR,CAAA;AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,iBAAA;AAAA,EACX,KAAA,EAAO,UAAA;AAAA,EACP,IAAA,CAAK,KAAA,EAAO,UAAA,EAAY,KAAA,EAAO,OAAO,GAAA,EAAK;AACvC,IAAA,MAAM,EAAA,GAAK,UAAU,UAAU,CAAA;AAC/B,IAAA,IAAI,CAAC,EAAA,EAAI;AACL,MAAA,MAAM,IAAI,KAAA,CAAM,CAAA,sCAAA,EAAyC,UAAU,CAAA,kBAAA,CAAoB,CAAA;AAAA,IAC3F;AACA,IAAA,MAAM,QAAQ,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,OAAO,KAAK,CAAA;AACtD,IAAA,OAAO,EAAE,IAAA,EAAM,CAAA,EAAG,EAAE,CAAA,CAAA,EAAI,MAAM,IAAI,CAAA,CAAA,CAAA,EAAK,IAAA,EAAM,KAAA,CAAM,IAAA,EAAK;AAAA,EAC5D;AACJ;;;;"}