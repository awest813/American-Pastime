{"version":3,"file":"bake-local-matrix.js","sources":["../../../src/loader-babylon/bake-local-matrix.ts"],"sourcesContent":["/** Bake localMatrix (pivot) into vertex positions and normals.\n *  Positions: full 4x3 affine. Normals: 3x3 part + renormalize.\n *  Dynamically imported only when the scene uses localMatrix. */\nexport function bakeLocalMatrix(positions: Float32Array, normals: Float32Array, lm: number[]): void {\n    const isIdentity =\n        lm[0] === 1 &&\n        lm[1] === 0 &&\n        lm[2] === 0 &&\n        lm[4] === 0 &&\n        lm[5] === 1 &&\n        lm[6] === 0 &&\n        lm[8] === 0 &&\n        lm[9] === 0 &&\n        lm[10] === 1 &&\n        lm[12] === 0 &&\n        lm[13] === 0 &&\n        lm[14] === 0;\n    if (isIdentity) {\n        return;\n    }\n\n    for (let i = 0; i < positions.length; i += 3) {\n        const x = positions[i]!,\n            y = positions[i + 1]!,\n            z = positions[i + 2]!;\n        positions[i] = x * lm[0]! + y * lm[4]! + z * lm[8]! + lm[12]!;\n        positions[i + 1] = x * lm[1]! + y * lm[5]! + z * lm[9]! + lm[13]!;\n        positions[i + 2] = x * lm[2]! + y * lm[6]! + z * lm[10]! + lm[14]!;\n    }\n\n    for (let i = 0; i < normals.length; i += 3) {\n        const nx = normals[i]!,\n            ny = normals[i + 1]!,\n            nz = normals[i + 2]!;\n        const rx = nx * lm[0]! + ny * lm[4]! + nz * lm[8]!;\n        const ry = nx * lm[1]! + ny * lm[5]! + nz * lm[9]!;\n        const rz = nx * lm[2]! + ny * lm[6]! + nz * lm[10]!;\n        const len = Math.sqrt(rx * rx + ry * ry + rz * rz);\n        if (len > 1e-10) {\n            normals[i] = rx / len;\n            normals[i + 1] = ry / len;\n            normals[i + 2] = rz / len;\n        }\n    }\n}\n"],"names":[],"mappings":"AAGO,SAAS,eAAA,CAAgB,SAAA,EAAyB,OAAA,EAAuB,EAAA,EAAoB;AAChG,EAAA,MAAM,UAAA,GACF,GAAG,CAAC,CAAA,KAAM,KACV,EAAA,CAAG,CAAC,MAAM,CAAA,IACV,EAAA,CAAG,CAAC,CAAA,KAAM,CAAA,IACV,GAAG,CAAC,CAAA,KAAM,KACV,EAAA,CAAG,CAAC,CAAA,KAAM,CAAA,IAC