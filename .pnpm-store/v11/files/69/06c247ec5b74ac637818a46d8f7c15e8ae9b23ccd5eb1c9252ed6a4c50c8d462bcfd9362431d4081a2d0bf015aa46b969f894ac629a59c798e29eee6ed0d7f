{"version":3,"file":"gltf-ext-anisotropy.js","sources":["../../../src/loader-gltf/gltf-ext-anisotropy.ts"],"sourcesContent":["/** glTF KHR_materials_anisotropy extension. */\nimport type { GltfFeature } from \"./gltf-feature.js\";\n\nconst ext: GltfFeature = {\n    id: \"KHR_materials_anisotropy\",\n    async applyMaterial(mat, ctx) {\n        const a = mat._rawMatDef?.extensions?.KHR_materials_anisotropy;\n        if (!a) {\n            return null;\n        }\n        const rot = a.anisotropyRotation ?? 0;\n        // anisotropyTexture is data (RG=direction, B=strength), so it is linear (not sRGB).\n        // ctx._texture applies wrapTex → KHR_texture_transform (sets _hasTx when animated).\n        const texture = a.anisotropyTexture ? await ctx._texture(a.anisotropyTexture, false) : undefined;\n        return {\n            anisotropy: {\n                isEnabled: true,\n                intensity: a.anisotropyStrength ?? 0,\n                direction: [Math.cos(rot), Math.sin(rot)],\n                texture,\n            },\n        };\n    },\n};\nexport default ext;\n"],"names":[],"mappings":"AAGA,MAAM,GAAA,GAAmB;AAAA,EACrB,EAAA,EAAI,0BAAA;AAAA,EACJ,MAAM,aAAA,CAAc,GAAA,EAAK,GAAA,EAAK;AAC1B,IAAA,MAAM,CAAA,GAAI,GAAA,CAAI,UAAA,EAAY,UAAA,EAAY,wBAAA;AACtC,IAAA,IAAI,CAAC,CAAA,EAAG;AACJ,MAAA,OAAO,IAAA;AAAA,IACX;AACA,IAAA,MAAM,GAAA,GAAM,EAAE,kBAAA,IAAsB,CAAA;AAGpC,IAAA,MAAM,OAAA,GAAU,EAAE,iBAAA,GAAoB,MAAM,IAAI,QAAA,CAAS,CAAA,CAAE,iBAAA,EAAmB,KAAK,CAAA,GAAI,MAAA;AACvF,IAAA,OAAO;AAAA,MACH,UAAA,EAAY;AAAA,QACR,SAAA,EAAW,IAAA;AAAA,QACX,SAAA,EAAW,EAAE,kBAAA,IAAsB,CAAA;AAAA,QACnC,SAAA,EAAW,CAAC,IAAA,CAAK,GAAA,CAAI,GAAG,CAAA,EAAG,IAAA,CAAK,GAAA,CAAI,GAAG,CAAC,CAAA;AAAA,QACxC;AAAA;AACJ,KACJ;AAAA,EACJ;AACJ;;;;"}