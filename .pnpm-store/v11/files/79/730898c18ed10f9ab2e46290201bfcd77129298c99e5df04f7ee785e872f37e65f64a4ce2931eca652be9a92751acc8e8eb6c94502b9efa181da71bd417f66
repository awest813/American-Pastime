{"version":3,"file":"cube-texture.js","sources":["../../../src/texture/cube-texture.ts"],"sourcesContent":["/** CubeTexture — loads 6 face images into a GPU cube texture with mipmaps. */\nimport { TU } from \"../engine/gpu-flags.js\";\nimport { getTrilinearSampler } from \"../resource/samplers.js\";\nimport { generateMipmaps } from \"./generate-mipmaps.js\";\nimport { mipLevelCount } from \"./mip-count.js\";\nimport type { EngineContext } from \"../engine/engine.js\";\n\ntype CubeResult = { texture: GPUTexture; view: GPUTextureView; sampler: GPUSampler };\nlet _cc: WeakMap<GPUDevice, Map<string, Promise<CubeResult>>> | null = null;\n\nexport function loadCubeTexture(engine: EngineContext, baseUrl: string, ext = \".jpg\"): Promise<CubeResult> {\n    const device = engine._device;\n    if (!_cc) {\n        _cc = new WeakMap();\n    }\n    let dc = _cc.get(device);\n    if (!dc) {\n        dc = new Map();\n        _cc.set(device, dc);\n    }\n    const key = `${baseUrl}\\0${ext}`;\n    const hit = dc.get(key);\n    if (hit) {\n        return hit;\n    }\n    const p = (async () => {\n        const bitmaps = await Promise.all(\n            [\"_px\", \"_nx\", \"_py\", \"_ny\", \"_pz\", \"_nz\"].map(async (s) => {\n                const r = await fetch(`${baseUrl}${s}${ext}`);\n                if (!r.ok) {\n                    throw new Error(`Cube face load failed: ${baseUrl}${s}${ext}`);\n                }\n                return createImageBitmap(await r.blob(), { premultiplyAlpha: \"none\", colorSpaceConversion: \"none\" });\n            })\n        );\n        const sz = bitmaps[0]!.width;\n        const tex = device.createTexture({\n            size: [sz, sz, 6],\n            format: \"rgba8unorm\",\n            dimension: \"2d\",\n            usage: TU.TEXTURE_BINDING | TU.COPY_DST | TU.RENDER_ATTACHMENT,\n            mipLevelCount: mipLevelCount(sz, sz),\n        });\n        for (let i = 0; i < 6; i++) {\n            device.queue.copyExternalImageToTexture({ source: bitmaps[i]! }, { texture: tex, origin: [0, 0, i], premultipliedAlpha: false }, [sz, sz, 1]);\n            bitmaps[i]!.close();\n            generateMipmaps(engine, tex, i);\n        }\n        return {\n            texture: tex,\n            view: tex.createView({ dimension: \"cube\", format: \"rgba8unorm\" }),\n            sampler: getTrilinearSampler(engine),\n        };\n    })();\n    dc.set(key, p);\n    p.catch(() => dc!.delete(key));\n    return p;\n}\n"],"names":[],"mappings":";;;;;AAQA,IAAI,GAAA,GAAmE,IAAA;AAEhE,SAAS,eAAA,CAAgB,MAAA,EAAuB,OAAA,EAAiB,GAAA,GAAM,MAAA,EAA6B;AACvG,EAAA,MAAM,SAAS,MAAA,CAAO,OAAA;AACtB,EAAA,IAAI,CAAC,GAAA,EAAK;AACN,IAAA,GAAA,uBAAU,OAAA,EAAQ;AAAA,EACtB;AACA,EAAA,IAAI,EAAA,GAAK,GAAA,CAAI,GAAA,CAAI,MAAM,CAAA;AACvB,EAAA,IAAI,CAAC,EAAA,EAAI;AACL,IAAA,EAAA,uBAAS,GAAA,EAAI;AACb,IAAA,GAAA,CAAI,GAAA,CAAI,QAAQ,EAAE,CAAA;AAAA,EACtB;AACA,EAAA,MAAM,GAAA,GAAM,CAAA,EAAG,OAAO,CAAA,EAAA,EAAK,GAAG,CAAA,CAAA;AAC9B,EAAA,MAAM,GAAA,GAAM,EAAA,CAAG,GAAA,CAAI,GAAG,CAAA;AACtB,EAAA,IAAI,GAAA,EAAK;AACL,IAAA,OAAO,GAAA;AAAA,EACX;AACA,EAAA,MAAM,KAAK,YAAY;AACnB,IAAA,MAAM,OAAA,GAAU,MAAM,OAAA,CAAQ,GAAA;AAAA,MAC1B,CAAC,KAAA,EAAO,KAAA,EAAO,KAAA,EAAO,KAAA,EAAO,OAAO,KAAK,CAAA,CAAE,GAAA,CAAI,OAAO,CAAA,KAAM;AACxD,QAAA,MAAM,CAAA,GAAI,MAAM,KAAA,CAAM,CAAA,EAAG,OAAO,CAAA,EAAG,CAAC,CAAA,EAAG,GAAG,CAAA,CAAE,CAAA;AAC5C,QAAA,IAAI,CAAC,EAAE,EAAA,EAAI;AACP,UAAA,MAAM,IAAI,MAAM,CAAA,uBAAA,EAA0B,OAAO,GAAG,CAAC,CAAA,EAAG,GAAG,CAAA,CAAE,CAAA;AAAA,QACjE;AACA,QAAA,OAAO,iBAAA,CAAkB,MAAM,CAAA,CAAE,IAAA,EAAK,EAAG,EAAE,gBAAA,EAAkB,MAAA,EAAQ,oBAAA,EAAsB,MAAA,EAAQ,CAAA;AAAA,MACvG,CAAC;AAAA,KACL;AACA,IAAA,MAAM,EAAA,GAAK,OAAA,CAAQ,CAAC,CAAA,CAAG,KAAA;AACvB,IAAA,MAAM,GAAA,GAAM,OAAO,aAAA,CAAc;AAAA,MAC7B,IAAA,EAAM,CAAC,EAAA,EAAI,EAAA,EAAI,CAAC,CAAA;AAAA,MAChB,MAAA,EAAQ,YAAA;AAAA,MACR,SAAA,EAAW,IAAA;AAAA,MACX,KAAA,EAAO,EAAA,CAAG,eAAA,GAAkB,EAAA,CAAG,WAAW,EAAA,CAAG,iBAAA;AAAA,MAC7C,aAAA,EAAe,aAAA,CAAc,EAAA,EAAI,EAAE;AAAA,KACtC,CAAA;AACD,IAAA,KAAA,IAAS,CAAA,GAAI,CAAA,EAAG,CAAA,GAAI,CAAA,EAAG,CAAA,