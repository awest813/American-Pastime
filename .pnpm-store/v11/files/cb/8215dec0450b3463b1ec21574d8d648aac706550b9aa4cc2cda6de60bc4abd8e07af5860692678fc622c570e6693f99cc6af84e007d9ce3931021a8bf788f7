{"version":3,"file":"panner-block.js","sources":["../../../../../src/material/node/blocks/panner-block.ts"],"sourcesContent":["/** PannerBlock — UV + speed * time.\n *\n * Babylon.js auto-configures `time` as an animated InputBlock, but serialized\n * graphs can also wire a constant. We simply evaluate the connected inputs; the\n * scene fixture uses a constant time value so output is deterministic.\n */\n\nimport type { BlockEmitter } from \"../node-types.js\";\n\nexport const emitter: BlockEmitter = {\n    className: \"PannerBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const uv = ctx.cast(ctx.resolve(block, \"uv\", stage, state), \"vec2f\");\n        const speed = ctx.cast(ctx.resolve(block, \"speed\", stage, state), \"vec2f\");\n        const time = ctx.cast(ctx.resolve(block, \"time\", stage, state), \"f32\");\n        return { expr: `(${uv.expr} + ${speed.expr} * ${time.expr})`, type: \"vec2f\" };\n    },\n};\n"],"names":[],"mappings":"AASO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,aAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,EAAA,GAAK,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,OAAO,IAAA,EAAM,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA;AACnE,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,OAAO,OAAA,EAAS,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA;AACzE,IAAA,MAAM,IAAA,GAAO,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,OAAO,MAAA,EAAQ,KAAA,EAAO,KAAK,CAAA,EAAG,KAAK,CAAA;AACrE,IAAA,OAAO,EAAE,IAAA,EAAM,CAAA,CAAA,EAAI,EAAA,CAAG,IAAI,CAAA,GAAA,EAAM,KAAA,CAAM,IAAI,CAAA,GAAA,EAAM,IAAA,CAAK,IAAI,CAAA,CAAA,CAAA,EAAK,MAAM,OAAA,EAAQ;AAAA,EAChF;AACJ;;;;"}