{"version":3,"file":"scale-block.js","sources":["../../../../../src/material/node/blocks/scale-block.ts"],"sourcesContent":["import type { BlockEmitter } from \"../node-types.js\";\n\nexport const emitter: BlockEmitter = {\n    className: \"ScaleBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const input = ctx.resolve(block, \"input\", stage, state);\n        const factor = ctx.resolve(block, \"factor\", stage, state);\n        // factor is always scalar in BJS\n        const fc = ctx.cast(factor, \"f32\").expr;\n        return { expr: `(${input.expr} * ${fc})`, type: input.type };\n    },\n};\n"],"names":[],"mappings":"AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,YAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,QAAQ,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,OAAO,KAAK,CAAA;AACtD,IAAA,MAAM,SAAS,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,QAAA,EAAU,OAAO,KAAK,CAAA;AAExD,IAAA,MAAM,EAAA,GAAK,GAAA,CAAI,IAAA,CAAK,MAAA,EAAQ,KAAK,CAAA,CAAE,IAAA;AACnC,IAAA,OAAO,EAAE,IAAA,EAAM,CAAA,CAAA,EAAI,KAAA,CAAM,IAAI,MAAM,EAAE,CAAA,CAAA,CAAA,EAAK,IAAA,EAAM,KAAA,CAAM,IAAA,EAAK;AAAA,EAC/D;AACJ;;;;"}