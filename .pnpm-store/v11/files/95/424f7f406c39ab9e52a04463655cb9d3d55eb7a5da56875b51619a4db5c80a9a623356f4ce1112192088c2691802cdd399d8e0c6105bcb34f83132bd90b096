{"version":3,"file":"mesh-attribute-exists-block.js","sources":["../../../../../src/material/node/blocks/mesh-attribute-exists-block.ts"],"sourcesContent":["/** MeshAttributeExistsBlock — per-mesh attribute branch.\n *\n * Babylon.js emits preprocessor branches based on the mesh attribute defines\n * (`UV1`, `TANGENT`, `VERTEXCOLOR_NME`, ...). Babylon Lite batches meshes that\n * share the same NME pipeline, so the equivalent decision is a per-mesh uniform\n * flag written beside the world matrix. Missing attributes still bind zero\n * buffers to satisfy the pipeline layout, but this block selects the serialized\n * fallback value when the real mesh attribute is absent.\n */\n\nimport type { BlockEmitter, NodeExpr } from \"../node-types.js\";\n\nfunction attributeFlag(attributeType: number): string | null {\n    switch (attributeType) {\n        case 1: // Normal\n            return \"1.0\";\n        case 2: // Tangent\n            return \"meshU.receivesShadow.z\";\n        case 3: // VertexColor\n            return \"meshU.receivesShadow.w\";\n        case 4: // UV1\n            return \"meshU.receivesShadow.y\";\n        case 5: // UV2\n            return \"0.0\";\n        case 6: // UV3\n        case 7: // UV4\n        case 8: // UV5\n        case 9: // UV6\n            return \"0.0\";\n        default:\n            return null;\n    }\n}\n\nexport const emitter: BlockEmitter = {\n    className: \"MeshAttributeExistsBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        state.usesMeshAttributeExists = true;\n        const input = ctx.resolve(block, \"input\", stage, state);\n        const flag = attributeFlag((block.serialized[\"attributeType\"] as number | undefined) ?? 0);\n        if (flag === null) {\n            return input;\n        }\n        const fallback = ctx.cast(ctx.resolve(block, \"fallback\", stage, state), input.type);\n        const expr = ctx.temp(state, \"attr\");\n        const s = stage === \"vertex\" ? state.vertex : state.fragment;\n        s.body.push(`let ${expr} = select(${fallback.expr}, ${input.expr}, ${flag} > 0.5);`);\n        return { expr, type: input.type } as NodeExpr;\n    },\n};\n"],"names":[],"mappings":"AAYA,SAAS,cAAc,aAAA,EAAsC;AACzD,EAAA,QAAQ,aAAA;AAAe,IACnB,KAAK,CAAA;AACD,MAAA,OAAO,KAAA;AAAA,IACX,KAAK,CAAA;AACD,MAAA,OAAO,wBAAA;AAAA,IACX,KAAK,CAAA;AACD,MAAA,OAAO,wBAAA;AAAA,IACX,KAAK,CAAA;AACD,MAAA,OAAO,wBAAA;AAAA,IACX,KAAK,CAAA;AACD,MAAA,OAAO,KAAA;AAAA,IACX,KAAK,CAAA;AAAA;AAAA,IACL,KAAK,CAAA;AAAA;AAAA,IACL,KAAK,CAAA;AAAA;AAAA,IACL,KAAK,CAAA;AACD,MAAA,OAAO,KAAA;AAAA,IACX;AACI,MAAA,OAAO,IAAA;AAAA;AAEnB;AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,0BAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,KAAA,CAAM,uBAAA,GAA0B,IAAA;AAChC,IAAA,MAAM,QAAQ,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,OAAO,KAAK,CAAA;AACtD,IAAA,MAAM,OAAO,aAAA,CAAe,KAAA,CAAM,UAAA,CAAW,eAAe,KAA4B,CAAC,CAAA;AACzF,IAAA,IAAI,SAAS,IAAA,EAAM;AACf,MAAA,OAAO,KAAA;AAAA,IACX;AACA,IAAA,MAAM,QAAA,GAAW,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,UAAA,EAAY,KAAA,EAAO,KAAK,CAAA,EAAG,KAAA,CAAM,IAAI,CAAA;AAClF,IAAA,MAAM,IAAA,GAAO,GAAA,CAAI,IAAA,CAAK,KAAA,EAAO,MAAM,CAAA;AACnC,IAAA,MAAM,CAAA,GAAI,KAAA,KAAU,QAAA,GAAW,KAAA,CAAM,SAAS,KAAA,CAAM,QAAA;AACpD,IAAA,CAAA,CAAE,IAAA,CAAK,IAAA,CAAK,CAAA,IAAA,EAAO,IAAI,CAAA,UAAA,EAAa,QAAA,CAAS,IAAI,CAAA,EAAA,EAAK,KAAA,CAAM,IAAI,CAAA,EAAA,EAAK,IAAI,CAAA,QAAA,CAAU,CAAA;AACnF,IAAA,OAAO,EAAE,IAAA,EAAM,IAAA,EAAM,KAAA,CAAM,IAAA,EAAK;AAAA,EACpC;AACJ;;;;"}