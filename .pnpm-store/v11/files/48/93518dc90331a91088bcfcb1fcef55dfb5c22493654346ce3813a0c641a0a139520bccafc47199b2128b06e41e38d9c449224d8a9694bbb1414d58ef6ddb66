{"version":3,"file":"screen-size-block.js","sources":["../../../../../src/material/node/blocks/screen-size-block.ts"],"sourcesContent":["/** ScreenSizeBlock — exposes current render size in physical canvas pixels. */\n\nimport type { BlockEmitter, NodeValueType } from \"../node-types.js\";\n\nconst OUTPUTS: Record<string, { readonly swizzle: string; readonly type: NodeValueType }> = {\n    xy: { swizzle: \"\", type: \"vec2f\" },\n    x: { swizzle: \".x\", type: \"f32\" },\n    y: { swizzle: \".y\", type: \"f32\" },\n};\n\nexport const emitter: BlockEmitter = {\n    className: \"ScreenSizeBlock\",\n    stage: \"fragment\",\n    emit(_block, outputName, _stage, state) {\n        state.usesScreenSize = true;\n        const out = OUTPUTS[outputName];\n        if (!out) {\n            throw new Error(`NodeMaterial: ScreenSizeBlock has no output \"${outputName}\"`);\n        }\n        return { expr: `_NME_SCREEN_SIZE_${out.swizzle}`, type: out.type };\n    },\n};\n"],"names":[],"mappings":"AAIA,MAAM,OAAA,GAAsF;AAAA,EACxF,EAAA,EAAI,EAAE,OAAA,EAAS,EAAA,EAAI,MAAM,OAAA,EAAQ;AAAA,EACjC,CAAA,EAAG,EAAE,OAAA,EAAS,IAAA,EAAM,MAAM,KAAA,EAAM;AAAA,EAChC,CAAA,EAAG,EAAE,OAAA,EAAS,IAAA,EAAM,MAAM,KAAA;AAC9B,CAAA;AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,iBAAA;AAAA,EACX,KAAA,EAAO,UAAA;AAAA,EACP,IAAA,CAAK,MAAA,EAAQ,UAAA,EAAY,MAAA,EAAQ,KAAA,EAAO;AACpC,IAAA,KAAA,CAAM,cAAA,GAAiB,IAAA;AACvB,IAAA,MAAM,GAAA,GAAM,QAAQ,UAAU,CAAA;AAC9B,IAAA,IAAI,CAAC,GAAA,EAAK;AACN,MAAA,MAAM,IAAI,KAAA,CAAM,CAAA,6CAAA,EAAgD,UAAU,CAAA,CAAA,CAAG,CAAA;AAAA,IACjF;AACA,IAAA,OAAO,EAAE,MAAM,CAAA,iBAAA,EAAoB,GAAA,CAAI,OAAO,CAAA,CAAA,EAAI,IAAA,EAAM,IAAI,IAAA,EAAK;AAAA,EACrE;AACJ;;;;"}