{"version":3,"file":"trigonometry-block.js","sources":["../../../../../src/material/node/blocks/trigonometry-block.ts"],"sourcesContent":["import type { BlockEmitter } from \"../node-types.js\";\n\n// Matches BJS `TrigonometryBlockOperations` enum.\nconst OP: Record<number, string> = {\n    0: \"cos\",\n    1: \"sin\",\n    2: \"abs\",\n    3: \"exp\",\n    4: \"exp2\",\n    5: \"round\",\n    6: \"floor\",\n    7: \"ceil\",\n    8: \"sqrt\",\n    9: \"log\",\n    10: \"tan\",\n    11: \"atan\",\n    12: \"acos\",\n    13: \"asin\",\n    14: \"fract\",\n    15: \"sign\",\n    16: \"radians\",\n    17: \"degrees\",\n};\n\nexport const emitter: BlockEmitter = {\n    className: \"TrigonometryBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const input = ctx.resolve(block, \"input\", stage, state);\n        const opIdx = block.serialized.operation;\n        const fn = typeof opIdx === \"number\" ? OP[opIdx] : undefined;\n        if (!fn) {\n            throw new Error(`NodeMaterial: unknown TrigonometryBlock operation ${String(opIdx)}`);\n        }\n        return { expr: `${fn}(${input.expr})`, type: input.type };\n    },\n};\n"],"names":[],"mappings":"AAGA,MAAM,EAAA,GAA6B;AAAA,EAC/B,CAAA,EAAG,KAAA;AAAA,EACH,CAAA,EAAG,KAAA;AAAA,EACH,CAAA,EAAG,KAAA;AAAA,EACH,CAAA,EAAG,KAAA;AAAA,EACH,CAAA,EAAG,MAAA;AAAA,EACH,CAAA,EAAG,OAAA;AAAA,EACH,CAAA,EAAG,OAAA;AAAA,EACH,CAAA,EAAG,MAAA;AAAA,EACH,CAAA,EAAG,MAAA;AAAA,EACH,CAAA,EAAG,KAAA;AAAA,EACH,EAAA,EAAI,KAAA;AAAA,EACJ,EAAA,EAAI,MAAA;AAAA,EACJ,EAAA,EAAI,MAAA;AAAA,EACJ,EAAA,EAAI,MAAA;AAAA,EACJ,EAAA,EAAI,OAAA;AAAA,EACJ,EAAA,EAAI,MAAA;AAAA,EACJ,EAAA,EAAI,SAAA;AAAA,EACJ,EAAA,EAAI;AACR,CAAA;AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,mBAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,QAAQ,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,OAAO,KAAK,CAAA;AACtD,IAAA,MAAM,KAAA,GAAQ,MAAM,UAAA,CAAW,SAAA;AAC/B,IAAA,MAAM,KAAK,OAAO,KAAA,KAAU,QAAA,GAAW,EAAA,CAAG,KAAK,CAAA,GAAI,MAAA;AACnD,IAAA,IAAI,CAAC,EAA