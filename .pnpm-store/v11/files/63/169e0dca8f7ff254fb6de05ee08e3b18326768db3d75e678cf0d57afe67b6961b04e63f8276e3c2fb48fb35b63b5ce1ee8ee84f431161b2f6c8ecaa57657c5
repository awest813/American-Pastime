   return { data: buffer };\n}\n\n/** Fetch + parse a `.spz` asset and attach the splat cloud to `scene`.\n *\n *  The returned mesh has `rotation.x = Math.PI` set on the scene node, matching\n *  the BJS reference convention. SPZ assets are authored \"Y-down\", and BJS\n *  compensates with `mesh.rotation.x = Math.PI` at scene-graph time. */\nexport async function loadSPZ(scene: SceneContext, url: string): Promise<GaussianSplattingMesh> {\n    const response = await fetch(url);\n    if (!response.ok) {\n        throw new Error(`loadSPZ: HTTP ${response.status} for ${url}`);\n    }\n    const raw = new U8(await response.arrayBuffer());\n    // SPZ files are conventionally gzip-wrapped; auto-detect the magic.\n    const isGzip = raw[0] === 0x1f && raw[1] === 0x8b;\n    const data: ArrayBuffer = isGzip ? ((await decompressGzip(raw)).buffer as ArrayBuffer) : (raw.buffer as ArrayBuffer);\n    const parsed = parseSpz(data);\n    const friendly = url.substring(url.lastIndexOf(\"/\") + 1) || \"spz\";\n    const mesh = await attachParsedSplat(scene, friendly, parsed);\n    mesh.rotation.x = Math.PI;\n    return mesh;\n}\n"],"names":[],"mappings":";;;AA+BA,MAAM,KAAA,GAAQ,mBAAA;AACd,MAAM,UAAA,GAAa,UAAA;AAGnB,eAAe,eAAe,KAAA,EAAwC;AAClE,EAAA,MAAM,SAAS,IAAI,QAAA,CAAS,IAAI,IAAA,CAAK,CAAC,KAAiB,CAAC,CAAA,CAAE,MAAA,GAAS,WAAA,CAAY,IAAI,mBAAA,CAAoB,MAAM,CAAC,CAAC,CAAA;AAC/G,EAAA,OAAO,IAAI,EAAA,CAAG,MAAM,MAAA,CAAO,aAAa,CAAA;AAC5C;AAGA,SAAS,gBAAA,CAAiB,EAAA,EAAgB,MAAA,EAAgB,aAAA,EAAuB,WAAuB,SAAA,EAA+B;AACnI,EAAA,SAAA,CAAU,CAAC,CAAA,GAAI,EAAA,CAAG,MAAA,GAAS,CAAC,CAAA;AAC5B,EAAA,SAAA,CAAU,CAAC,CAAA,GAAI,EAAA,CAAG,MAAA,GAAS,CAAC,CAAA;AAC5B,EAAA,SAAA,CAAU,CAAC,CAAA,GAAI,EAAA,CAAG,MAAA,GAAS,CAAC,CAAA;AAC5B,EAAA,SAAA,CAAU,CAAC,KAAK,EAAA,CAAG,MAAA,GAAS,CAAC,CAAA,GAAK,GAAA,MAAU,IAAI,GAAA,GAAO,CAAA;AACvD,EAAA,OAAO,SAAA,CAAU,CAAC,CAAA,GAAK,aAAA;AAC3B;AAEA,MAAM,QAAA,GAAW,CAAC,CAAA,KAAuB,CAAA,GAAI,IAAI,CAAA,GAAI,CAAA,GAAI,MAAM,GAAA,GAAM,CAAA;AAGrE,SAAS,SAAS,IAAA,EAAgC;AAC9C,EAAA,MAAM,IAAA,GAAO,IAA