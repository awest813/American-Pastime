{"version":3,"file":"desaturate-block.js","sources":["../../../../../src/material/node/blocks/desaturate-block.ts"],"sourcesContent":["import type { BlockEmitter } from \"../node-types.js\";\n\nexport const emitter: BlockEmitter = {\n    className: \"DesaturateBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const color = ctx.cast(ctx.resolve(block, \"color\", stage, state), \"vec3f\").expr;\n        const level = ctx.cast(ctx.resolve(block, \"level\", stage, state), \"f32\").expr;\n        const minColor = `min(min((${color}).x, (${color}).y), (${color}).z)`;\n        const maxColor = `max(max((${color}).x, (${color}).y), (${color}).z)`;\n        const merge = `(0.5 * (${minColor} + ${maxColor}))`;\n        return { expr: `mix(${color}, vec3<f32>(${merge}), ${level})`, type: \"vec3f\" };\n    },\n};\n"],"names":[],"mappings":"AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,iBAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA,CAAE,IAAA;AAC3E,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,KAAA,EAAO,KAAK,CAAA,EAAG,KAAK,CAAA,CAAE,IAAA;AACzE,IAAA,MAAM,WAAW,CAAA,SAAA,EAAY,KAAK,CAAA,MAAA,EAAS,KAAK,UAAU,KAAK,CAAA,IAAA,CAAA;AAC/D,IAAA,MAAM,WAAW,CAAA,SAAA,EAAY,KAAK,CAAA,MAAA,EAAS,KAAK,UAAU,KAAK,CAAA,IAAA,CAAA;AAC/D,IAAA,MAAM,KAAA,GAAQ,CAAA,QAAA,EAAW,QAAQ,CAAA,GAAA,EAAM,QAAQ,CAAA,EAAA,CAAA;AAC/C,IAAA,OAAO,EAAE,IAAA,EAAM,CAAA,IAAA,EAAO,KAAK,CAAA,YAAA,EAAe,KAAK,CAAA,GAAA,EAAM,KAAK,CAAA,CAAA,CAAA,EAAK,IAAA,EAAM,OAAA,EAAQ;AAAA,EACjF;AACJ;;;;"}