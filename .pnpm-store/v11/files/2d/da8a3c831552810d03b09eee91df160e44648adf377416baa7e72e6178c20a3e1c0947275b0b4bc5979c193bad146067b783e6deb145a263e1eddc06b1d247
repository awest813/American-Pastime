{"version":3,"file":"quat-from-rotation-matrix.js","sources":["../../../src/math/quat-from-rotation-matrix.ts"],"sourcesContent":["/** Build a unit quaternion from the rotation part of a 4×4 matrix.\n *  Standalone function for tree-shaking — only bundled when used. */\n\nimport type { Mat4, Quat } from \"./types.js\";\n\n/** Build a unit quaternion from a 3×3 rotation basis (column-major element names:\n *  m11/m21/m31 = column 0, m12/m22/m32 = column 1, m13/m23/m33 = column 2). Uses\n *  Shepperd's trace method, byte-for-byte matching Babylon.js\n *  `Quaternion.FromRotationMatrix`.\n *  @internal */\nexport function _quatFromRotationBasis(m11: number, m12: number, m13: number, m21: number, m22: number, m23: number, m31: number, m32: number, m33: number): Quat {\n    const trace = m11 + m22 + m33;\n    let s: number;\n    if (trace > 0) {\n        s = 0.5 / Math.sqrt(trace + 1.0);\n        return { x: (m32 - m23) * s, y: (m13 - m31) * s, z: (m21 - m12) * s, w: 0.25 / s };\n    }\n    if (m11 > m22 && m11 > m33) {\n        s = 2.0 * Math.sqrt(1.0 + m11 - m22 - m33);\n        return { x: 0.25 * s, y: (m12 + m21) / s, z: (m13 + m31) / s, w: (m32 - m23) / s };\n    }\n    if (m22 > m33) {\n        s = 2.0 * Math.sqrt(1.0 + m22 - m11 - m33);\n        return { x: (m12 + m21) / s, y: 0.25 * s, z: (m23 + m32) / s, w: (m13 - m31) / s };\n    }\n    s = 2.0 * Math.sqrt(1.0 + m33 - m11 - m22);\n    return { x: (m13 + m31) / s, y: (m23 + m32) / s, z: 0.25 * s, w: (m21 - m12) / s };\n}\n\n/**\n * Build a unit quaternion from the rotation part of a column-major 4×4 matrix,\n * matching Babylon.js `Quaternion.FromRotationMatrix`. The matrix's upper-left\n * 3×3 must be a pure rotation (orthonormal, no scale).\n * @param matrix - Column-major 4×4 rotation matrix.\n * @returns A new `{ x, y, z, w }` quaternion.\n */\nexport function quatFromRotationMatrix(matrix: Mat4): Quat {\n    return _quatFromRotationBasis(matrix[0]!, matrix[4]!, matrix[8]!, matrix[1]!, matrix[5]!, matrix[9]!, matrix[2]!, matrix[6]!, matrix[10]!);\n}\n"],"names":[],"mappings":"AAUO,SAAS,sBAAA,CAAuB,KAAa,GAAA,EAAa,GAAA,EAAa,KAAa,GAAA,EAAa,GAAA,EAAa,GAAA,EAAa,GAAA,EAAa,GAAA,EAAmB;AAC9J,EAAA,MAAM,KAAA,GAAQ,MAAM,GAAA,GAAM,GAAA;AAC1B,EAAA,IAAI,CAAA;AACJ,EAAA,IAAI,QAAQ,CAAA,EAAG;AACX,IAAA,CAAA,GAAI,GAAA,GAAM,IAAA,CAAK,IAAA,CAAK,KAAA,GAAQ,CAAG,CAAA;AAC/B,IAAA,OAAO,EAAE,CAAA,EAAA,CAAI,GAAA,GAAM,GAAA,IAAO,GAAG,CAAA,EAAA,CAAI,GAAA,GAAM,GAAA,IAAO,CAAA,EAAG,IAAI,GAAA,GAAM,GAAA,IAAO,CAAA,EAAG,CAAA,EAAG,OAAO,CAAA,EAAE;AAAA,EACrF;AACA,EAAA,IAAI,GAAA,GAAM,GAAA,IAAO,GAAA,GAAM,GAAA,EAAK;AACxB,IAAA,CAAA,GAAI,IAAM,IAAA,CAAK,IAAA,CAAK,CAAA,GAAM,GAAA,GAAM,MAAM,GAAG,CAAA;AACzC,IAAA,OAAO,EAAE,CAAA,EAAG,IAAA,GAAO,CAAA,EAAG,IAAI,GAAA,GAAM,GAAA,IAAO,CAAA,EAAG,CAAA,EAAA,CAAI,MAAM,GAAA,IAAO,CAAA,EAAG,CAAA,EAAA,CAAI,GAAA,GAAM,OAAO,CAAA,EAAE;AAAA,EACrF;AACA,EAAA,IAAI,MAAM,GAAA,EAAK;AACX,IAAA,CAAA,GAAI,IAAM,IAAA,CAAK,IAAA,CAAK,CAAA,GAAM,GAAA,GAAM,MAAM,GAAG,CAAA;AACzC,IAAA,OAAO,EAAE,CAAA,EAAA,CAAI,GAAA,GAAM,GAAA,IAAO,GAAG,CAAA,EAAG,IAAA,GAAO,CAAA,EAAG,CAAA,EAAA,CAAI,MAAM,GAAA,IAAO,CAAA,EAAG,CAAA,EAAA,CAAI,GAAA,GAAM,OAAO,CAAA,EAAE;AAAA,EACrF;AACA,EAAA,CAAA,GAAI,IAAM,IAAA,CAAK,IAAA,CAAK,CAAA,GAAM,GAAA,GAAM,MAAM,GAAG,CAAA;AACzC,EAAA,OAAO,EAAE,CAAA,EAAA,CAAI,GAAA,GAAM,GAAA,IAAO,GAAG,CAAA,EAAA,CAAI,GAAA,GAAM,GAAA,IAAO,CAAA,EAAG,GAAG,IAAA,GAAO,CAAA,EAAG,CAAA,EAAA,CAAI,GAAA,GAAM,OAAO,CAAA,EAAE;AACrF;AASO,SAAS,uBAAuB,MAAA,EAAoB;AACvD,EAAA,OAAO,sBAAA,CAAuB,MAAA,CAAO,CAAC,CAAA,EAAI,MAAA,CAAO,CAAC,CAAA,EAAI,MAAA,CAAO,CAAC,CAAA,EAAI,MAAA,CAAO,CAAC,CAAA,EAAI,MAAA,CAAO,CAAC,CAAA,EAAI,MAAA,CAAO,CAAC,CAAA,EAAI,MAAA,CAAO,CAAC,CAAA,EAAI,MAAA,CAAO,CAAC,CAAA,EAAI,MAAA,CAAO,EAAE,CAAE,CAAA;AAC7I;;;;"}