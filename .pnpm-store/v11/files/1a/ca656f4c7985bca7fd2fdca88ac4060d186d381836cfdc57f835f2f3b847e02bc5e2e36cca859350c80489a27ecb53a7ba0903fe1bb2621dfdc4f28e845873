{"version":3,"file":"mat4-decompose.js","sources":["../../../src/math/mat4-decompose.ts"],"sourcesContent":["/** Decompose a column-major 4×4 affine matrix into translation, rotation, and scale.\n *  Standalone function for tree-shaking — only bundled when used. */\n\nimport type { Mat4, Quat, Vec3 } from \"./types.js\";\nimport { _quatFromRotationBasis } from \"./quat-from-rotation-matrix.js\";\n\n/** Result of {@link mat4Decompose}: a TRS triple. */\nexport interface DecomposedTransform {\n    /** Translation (matrix columns 12/13/14). */\n    translation: Vec3;\n    /** Rotation as a unit quaternion. */\n    rotation: Quat;\n    /** Per-axis scale (lengths of the basis columns). */\n    scale: Vec3;\n}\n\n/**\n * Decompose a column-major 4×4 affine matrix into translation, rotation (unit\n * quaternion), and scale. Assumes a TRS matrix (no shear). Mirror image (negative\n * determinant) matrices are not specially handled — the returned scale is always\n * non-negative, matching the rest of the engine's decompose usage.\n * @param m - Column-major 4×4 matrix.\n * @returns A new translation/rotation/scale triple.\n */\nexport function mat4Decompose(m: Mat4): DecomposedTransform {\n    const sx = Math.hypot(m[0]!, m[1]!, m[2]!);\n    const sy = Math.hypot(m[4]!, m[5]!, m[6]!);\n    const sz = Math.hypot(m[8]!, m[9]!, m[10]!);\n    const invSx = sx > 1e-8 ? 1 / sx : 0;\n    const invSy = sy > 1e-8 ? 1 / sy : 0;\n    const invSz = sz > 1e-8 ? 1 / sz : 0;\n    // Strip scale from the basis columns, then extract the rotation quaternion.\n    const q = _quatFromRotationBasis(m[0]! * invSx, m[4]! * invSy, m[8]! * invSz, m[1]! * invSx, m[5]! * invSy, m[9]! * invSz, m[2]! * invSx, m[6]! * invSy, m[10]! * invSz);\n    // Renormalize — dividing by per-axis scale introduces small drift.\n    const invLen = 1 / Math.hypot(q.x, q.y, q.z, q.w);\n    return {\n        translation: { x: m[12]!, y: m[13]!, z: m[14]! },\n        rotation: { x: q.x * invLen, y: q.y * invLen, z: q.z * invLen, w: q.w * invLen },\n        scale: { x: sx, y: sy, z: sz },\n    };\n}\n"],"names":[],"mappings":";;AAwBO,SAAS,cAAc,CAAA,EAA8B;AACxD,EAAA,MAAM,EAAA,GAAK,IAAA,CAAK,KAAA,CAAM,CAAA,CAAE,CAAC,CAAA,EAAI,CAAA,CAAE,CAAC,CAAA,EAAI,CAAA,CAAE,CAAC,CAAE,CAAA;AACzC,EAAA,MAAM,EAAA,GAAK,IAAA,CAAK,KAAA,CAAM,CAAA,CAAE,CAAC,CAAA,EAAI,CAAA,CAAE,CAAC,CAAA,EAAI,CAAA,CAAE,CAAC,CAAE,CAAA;AACzC,EAAA,MAAM,EAAA,GAAK,IAAA,CAAK,KAAA,CAAM,CAAA,CAAE,CAAC,CAAA,EAAI,CAAA,CAAE,CAAC,CAAA,EAAI,CAAA,CAAE,EAAE,CAAE,CAAA;AAC1C,EAAA,MAAM,KAAA,GAAQ,EAAA,GAAK,IAAA,GAAO,CAAA,GAAI,EAAA,GAAK,CAAA;AACnC,EAAA,MAAM,KAAA,GAAQ,EAAA,GAAK,IAAA,GAAO,CAAA,GAAI,EAAA,GAAK,CAAA;AACnC,EAAA,MAAM,KAAA,GAAQ,EAAA,GAAK,IAAA,GAAO,CAAA,GAAI,EAAA,GAAK,CAAA;AAEnC,EAAA,MAAM,IAAI,sBAAA,CAAuB,CAAA,CAAE,CAAC,CAAA,GAAK,OAAO,CAAA,CAAE,CAAC,CAAA,GAAK,KAAA,EAAO,EAAE,CAAC,CAAA,GAAK,KAAA,EAAO,CAAA,CAAE,CAAC,CAAA,GAAK,KAAA,EAAO,CAAA,CAAE,CAAC,IAAK,KAAA,EAAO,CAAA,CAAE,CAAC,CAAA,GAAK,OAAO,CAAA,CAAE,CAAC,CAAA,GAAK,KAAA,EAAO,EAAE,CAAC,CAAA,GAAK,OAAO,CAAA,CAAE,EAAE,IAAK,KAAK,CAAA;AAEvK,EAAA,MAAM,MAAA,GAAS,CAAA,GAAI,IAAA,CAAK,KAAA,CAAM,CAAA,CAAE,CAAA,EAAG,CAAA,CAAE,CAAA,EAAG,CAAA,CAAE,CAAA,EAAG,CAAA,CAAE,CAAC,CAAA;AAChD,EAAA,OAAO;AAAA,IACH,WAAA,EAAa,EAAE,CAAA,EAAG,CAAA,CAAE,EAAE,CAAA,EAAI,CAAA,EAAG,CAAA,CAAE,EAAE,CAAA,EAAI,CAAA,EAAG,CAAA,CAAE,EAAE,CAAA,EAAG;AAAA,IAC/C,UAAU,EAAE,CAAA,EAAG,CAAA,CAAE,CAAA,GAAI,QAAQ,CAAA,EAAG,CAAA,CAAE,CAAA,GAAI,MAAA,EAAQ,GAAG,CAAA,CAAE,CAAA,GAAI,QAAQ,CAAA,EAAG,CAAA,CAAE,IAAI,MAAA,EAAO;AAAA,IAC/E,OAAO,EAAE,CAAA,EAAG,IAAI,CAAA,EAAG,EAAA,EAAI,GAAG,EAAA;AAAG,GACjC;AACJ;;;;"}