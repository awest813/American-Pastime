{"version":3,"file":"twirl-block.js","sources":["../../../../../src/material/node/blocks/twirl-block.ts"],"sourcesContent":["/** TwirlBlock — rotates a vec2 around a center by strength * distance, then adds offset. */\n\nimport type { BlockEmitter, NodeValueType } from \"../node-types.js\";\n\nconst OUTPUTS: Record<string, { readonly swizzle: string; readonly type: NodeValueType }> = {\n    output: { swizzle: \"\", type: \"vec2f\" },\n    x: { swizzle: \".x\", type: \"f32\" },\n    y: { swizzle: \".y\", type: \"f32\" },\n};\n\nfunction defaultVec2(expr: string): { readonly expr: string; readonly type: \"vec2f\" } {\n    return { expr, type: \"vec2f\" };\n}\n\nfunction defaultF32(expr: string): { readonly expr: string; readonly type: \"f32\" } {\n    return { expr, type: \"f32\" };\n}\n\nexport const emitter: BlockEmitter = {\n    className: \"TwirlBlock\",\n    stage: \"fragment\",\n    emit(block, outputName, stage, state, ctx) {\n        const input = ctx.cast(ctx.resolve(block, \"input\", stage, state), \"vec2f\");\n        const strength = ctx.cast(block.inputs.get(\"strength\")?.source ? ctx.resolve(block, \"strength\", stage, state) : defaultF32(\"1.0\"), \"f32\");\n        const center = ctx.cast(block.inputs.get(\"center\")?.source ? ctx.resolve(block, \"center\", stage, state) : defaultVec2(\"vec2<f32>(0.5, 0.5)\"), \"vec2f\");\n        const offset = ctx.cast(block.inputs.get(\"offset\")?.source ? ctx.resolve(block, \"offset\", stage, state) : defaultVec2(\"vec2<f32>(0.0, 0.0)\"), \"vec2f\");\n        const delta = ctx.temp(state, \"twirlDelta\");\n        const angle = ctx.temp(state, \"twirlAngle\");\n        const result = ctx.temp(state, \"twirl\");\n        state.fragment.body.push(`let ${delta} = ${input.expr} - ${center.expr};`);\n        state.fragment.body.push(`let ${angle} = ${strength.expr} * length(${delta});`);\n        state.fragment.body.push(\n            `let ${result} = vec2<f32>(cos(${angle}) * ${delta}.x - sin(${angle}) * ${delta}.y, sin(${angle}) * ${delta}.x + cos(${angle}) * ${delta}.y) + ${center.expr} + ${offset.expr};`\n        );\n        const out = OUTPUTS[outputName];\n        if (!out) {\n            throw new Error(`NodeMaterial: TwirlBlock has no output \"${outputName}\"`);\n        }\n        return { expr: `${result}${out.swizzle}`, type: out.type };\n    },\n};\n"],"names":[],"mappings":"AAIA,MAAM,OAAA,GAAsF;AAAA,EACxF,MAAA,EAAQ,EAAE,OAAA,EAAS,EAAA,EAAI,MAAM,OAAA,EAAQ;AAAA,EACrC,CAAA,EAAG,EAAE,OAAA,EAAS,IAAA,EAAM,MAAM,KAAA,EAAM;AAAA,EAChC,CAAA,EAAG,EAAE,OAAA,EAAS,IAAA,EAAM,MAAM,KAAA;AAC9B,CAAA;AAEA,SAAS,YAAY,IAAA,EAAiE;AAClF,EAAA,OAAO,EAAE,IAAA,EAAM,IAAA,EAAM,OAAA,EAAQ;AACjC;AAEA,SAAS,WAAW,IAAA,EAA+D;AAC/E,EAAA,OAAO,EAAE,IAAA,EAAM,IAAA,EAAM,KAAA,EAAM;AAC/B;AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,YAAA;AAAA,EACX,KAAA,EAAO,UAAA;AAAA,EACP,IAAA,CAAK,KAAA,EAAO,UAAA,EAAY,KAAA,EAAO,OAAO,GAAA,EAAK;AACvC,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,OAAO,OAAA,EAAS,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA;AACzE,IAAA,MAAM,WAAW,GAAA,CAAI,IAAA,CAAK,MAAM,MAAA,CAAO,GAAA,CAAI,UAAU,CAAA,EAAG,MAAA,GAAS,IAAI,OAAA,CAAQ,KAAA,EAAO,YAAY,KAAA,EAAO,KAAK,IAAI,UAAA,CAAW,KAAK,GAAG,KAAK,CAAA;AACxI,IAAA,MAAM,SAAS,GAAA,CAAI,IAAA,CAAK,MAAM,MAAA,CAAO,GAAA,CAAI,QAAQ,CAAA,EAAG,MAAA,GAAS,IAAI,OAAA,CAAQ,KAAA,EAAO,UAAU,KAAA,EAAO,KAAK,IAAI,WAAA,CAAY,qBAAqB,GAAG,OAAO,CAAA;AACrJ,IAAA,MAAM,SAAS,GAAA,CAAI,IAAA,CAAK,MAAM,MAAA,CAAO,GAAA,CAAI,QAAQ,CAAA,EAAG,MAAA,GAAS,IAAI,OAAA,CAAQ,KAAA,EAAO,UAAU,KAAA,EAAO,KAAK,IAAI,WAAA,CAAY,qBAAqB,GAAG,OAAO,CAAA;AACrJ,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,KAAA,EAAO,YAAY,CAAA;AAC1C,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,KAAA,EAAO,YAAY,CAAA;AAC1C,IAAA,MAAM,MAAA,GAAS,GAAA,CAAI,IAAA,CAAK,KAAA,EAAO,OAAO,CAAA;AACtC,IAAA,KAAA,CAAM,QAAA,CAAS,IAAA,CAAK,IAAA,CAAK,CAAA,IAAA,EAAO,KAAK,CAAA,GAAA,EAAM,KAAA,CAAM,IAAI,CAAA,GAAA,EAAM,MAAA,CAAO,IAAI,CAAA,CAAA,CAAG,CAAA;AACzE,IAAA,KAAA,CAAM,QAAA,CAAS,IAAA,CAAK,IAAA,CAAK,CAAA,IAAA,EAAO,KAAK,MAAM,QAAA,CAAS,IAAI,CAAA,UAAA,EAAa,KAAK,CAAA,EAAA,CAAI,CAA