{"version":3,"file":"light-matrix.js","sources":["../../../src/light/light-matrix.ts"],"sourcesContent":["/** Shared light matrix helper — builds a local matrix from a direction vector + optional position. */\n\nimport { F32 } from \"../engine/typed-arrays.js\";\nimport type { Mat4 } from \"../math/types.js\";\nimport type { Mat4Storage } from \"../math/types.js\";\n\n/** Build a local matrix from a direction vector + optional position.\n *  Column 2 = forward (normalized direction), column 0 = right, column 1 = up. */\nexport function localMatrixFromDirection(dx: number, dy: number, dz: number, px = 0, py = 0, pz = 0, out?: Mat4): Mat4 {\n    const flen = Math.sqrt(dx * dx + dy * dy + dz * dz) || 1;\n    const fx = dx / flen,\n        fy = dy / flen,\n        fz = dz / flen;\n\n    // Right = normalize(cross(worldUp, forward))\n    let rx = -fz,\n        rz = fx;\n    const ry = 0;\n    const rlen = Math.sqrt(rx * rx + ry * ry + rz * rz) || 1;\n    rx /= rlen;\n    rz /= rlen;\n\n    // Up = cross(forward, right)\n    const ux = fy * rz - fz * ry,\n        uy = fz * rx - fx * rz,\n        uz = fx * ry - fy * rx;\n\n    // F32 fallback used only when callers don't pass `out`. Light factories\n    // always pass a policy-allocated `_localMatrix` as `out` (see Task 2.3),\n    // so the F32 path is exercised only by ad-hoc / test usage.\n    const out4: Mat4 = out ?? (new F32(16) as unknown as Mat4);\n    const m = out4 as unknown as Mat4Storage;\n    m[0] = rx;\n    m[1] = ry;\n    m[2] = rz;\n    m[3] = 0;\n    m[4] = ux;\n    m[5] = uy;\n    m[6] = uz;\n    m[7] = 0;\n    m[8] = fx;\n    m[9] = fy;\n    m[10] = fz;\n    m[11] = 0;\n    m[12] = px;\n    m[13] = py;\n    m[14] = pz;\n    m[15] = 1;\n    return out4;\n}\n"],"names":[],"mappings":";;AAQO,SAAS,wBAAA,CAAyB,EAAA,EAAY,EAAA,EAAY,EAAA,EAAY,EAAA,GAAK,GAAG,EAAA,GAAK,CAAA,EAAG,EAAA,GAAK,CAAA,EAAG,GAAA,EAAkB;AACnH,EAAA,MAAM,IAAA,GAAO,KAAK,IAAA,CAAK,EAAA,GAAK,KAAK,EAAA,GAAK,EAAA,GAAK,EAAA,GAAK,EAAE,CAAA,IAAK,CAAA;