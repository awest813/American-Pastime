{"version":3,"file":"parse-camera.js","sources":["../../../src/loader-babylon/parse-camera.ts"],"sourcesContent":["/** Parse a FreeCamera from .babylon camera data. Dynamically imported by load-babylon.ts. */\nimport { createFreeCamera } from \"../camera/free-camera.js\";\nimport type { FreeCamera } from \"../camera/free-camera.js\";\n\nexport function parseBabylonCamera(cd: { position: number[]; rotation?: number[]; fov?: number; minZ?: number; maxZ?: number }): FreeCamera {\n    const p = cd.position;\n    const pitch = cd.rotation?.[0] ?? 0;\n    const yaw = cd.rotation?.[1] ?? 0;\n    const cp = Math.cos(pitch);\n    const cam = createFreeCamera({ x: p[0]!, y: p[1]!, z: p[2]! }, { x: p[0]! + cp * Math.sin(yaw), y: p[1]! - Math.sin(pitch), z: p[2]! + cp * Math.cos(yaw) });\n    if (cd.fov != null) {\n        cam.fov = cd.fov;\n    }\n    if (cd.minZ != null) {\n        cam.nearPlane = cd.minZ;\n    }\n    if (cd.maxZ != null) {\n        cam.farPlane = cd.maxZ;\n    }\n    return cam;\n}\n"],"names":[],"mappings":";;AAIO,SAAS,mBAAmB,EAAA,EAAyG;AACxI,EAAA,MAAM,IAAI,EAAA,CAAG,QAAA;AACb,EAAA,MAAM,KAAA,GAAQ,EAAA,CAAG,QAAA,GAAW,CAAC,CAAA,IAAK,CAAA;AAClC,EAAA,MAAM,GAAA,GAAM,EAAA,CAAG,QAAA,GAAW,CAAC,CAAA,IAAK,CAAA;AAChC,EAAA,MAAM,EAAA,GAAK,IAAA,CAAK,GAAA,CAAI,KAAK,CAAA;AACzB,EAAA,MAAM,MAAM,gBAAA,CAAiB,EAAE,GAAG,CAAA,CAAE,CAAC,GAAI,CAAA,EAAG,CAAA,CAAE,CAAC,CAAA,EAAI,CAAA,EAAG,EAAE,CAAC,CAAA,IAAM,EAAE,CAAA,EAAG,EAAE,CAAC,CAAA,GAAK,KAAK,IAAA,CAAK,GAAA,CAAI,GAAG,CAAA,EAAG,CAAA,EAAG,EAAE,CAAC,CAAA,GAAK,KAAK,GAAA,CAAI,KAAK,GAAG,CAAA,EAAG,CAAA,CAAE,CAAC,CAAA,GAAK,EAAA,GAAK,KAAK,GAAA,CAAI,GAAG,GAAG,CAAA;AAC3J,EAAA,IAAI,EAAA,CAAG,OAAO,IAAA,EAAM;AAChB,IAAA,GAAA,CAAI,MAAM,EAAA,CAAG,GAAA;AAAA,EACjB;AACA,EAAA,IAAI,EAAA,CAAG,QAAQ,IAAA,EAAM;AACjB,IAAA,GAAA,CAAI,YAAY,EAAA,CAAG,IAAA;AAAA,EACvB;AACA,EAAA,IAAI,EAAA,CAAG,QAAQ,IAAA,EAAM;AACjB,IAAA,GAAA,CAAI,WAAW,EAAA,CAAG,IAAA;AAAA,EACtB;AACA,EAAA,OAAO,GAAA;AACX;;;;"}