{"version":3,"file":"gltf-multi-buffer.js","sources":["../../../src/loader-gltf/gltf-multi-buffer.ts"],"sourcesContent":["/** Multi-buffer glTF support.\n *\n *  Dynamic-imported by load-gltf.ts ONLY when an asset declares more than one\n *  buffer (separate geometry / animation / skin `.bin` files — e.g. Khronos\n *  AnimatedTriangle, SimpleSkin). Single-buffer glTF and GLB assets never load\n *  this module, so they pay zero bytes for it.\n *\n *  Lite reads every accessor through one `binChunk` DataView and ignores\n *  `bufferView.buffer`. To keep that fast single-chunk reader unchanged, this\n *  fetches all buffers, concatenates them (each 4-byte aligned so float\n *  accessors stay aligned), and rewrites every `bufferView.byteOffset` to its\n *  global position in the concatenated chunk (and resets `buffer` to 0). */\n\nexport async function loadMultiBuffer(json: any, baseUrl: string): Promise<DataView> {\n    const buffers: any[] = json.buffers ?? [];\n    const arrays = await Promise.all(buffers.map((b) => (b?.uri ? fetch(resolveBufferUri(b.uri, baseUrl)).then((r) => r.arrayBuffer()) : Promise.resolve(new ArrayBuffer(0)))));\n\n    // Place each buffer at a 4-byte-aligned offset; record starts for the rewrite.\n    const offsets: number[] = [];\n    let total = 0;\n    for (const a of arrays) {\n        offsets.push(total);\n        total += a.byteLength;\n        total = (total + 3) & ~3;\n    }\n\n    const out = new Uint8Array(total);\n    for (let i = 0; i < arrays.length; i++) {\n        out.set(new Uint8Array(arrays[i]!), offsets[i]!);\n    }\n\n    for (const bv of json.bufferViews ?? []) {\n        bv.byteOffset = (bv.byteOffset ?? 0) + offsets[bv.buffer ?? 0]!;\n        bv.buffer = 0;\n    }\n\n    return new DataView(out.buffer);\n}\n\nfunction resolveBufferUri(uri: string, baseUrl: string): string {\n    if (baseUrl) {\n        return new URL(uri, baseUrl + \"x\").href;\n    }\n    try {\n        return new URL(uri).href;\n    } catch {\n        throw new Error(\"loadGltf: relative buffer URI needs a base URL.\");\n    }\n}\n"],"names":[],"mappings":"AAaA,eAAsB,eAAA,CAAgB,MAAW,OAAA,EAAoC;AACjF,EAAA,MAAM,OAAA,GAAiB,IAAA,CAAK,OAAA,IAAW,EAAC;AACxC,EAAA,MAAM,MAAA,GAAS,MAAM,OAAA,CAAQ,GAAA,CAAI,OAAA,CAAQ,GAAA,CAAI,CAAC,CAAA,KAAO,CAAA,EAAG,GAAA,GAAM,KAAA,CAAM,gBAAA,CAAiB,EAAE,GAAA,EAAK,OAAO,CAAC,CAAA,CAAE,IAAA,CAAK,CAAC,CAAA,KAAM,CAAA,CAAE,aAAa,CAAA,GAAI,OAAA,CAAQ,OAAA,CAAQ,IAAI,WAAA,CAAY,CAAC,CAAC,CAAE,CAAC,CAAA;AAG1K,EAAA,MAAM,UAAoB,EAAC;AAC3B,EAAA,IAAI,KAAA,GAAQ,CAAA;AACZ,EAAA,KAAA,MAAW,KAAK,MAAA,EAAQ;AACpB,IAAA,OAAA,CAAQ,KAAK,KAAK,CAAA;AAClB,IAAA,KAAA,IAAS,CAAA,CAAE,UAAA;AACX,IAAA,KAAA,GAAS,KAAA,GAAQ,IAAK,EAAC;AAAA,EAC3B;AAEA,EAAA,MAAM,GAAA,GAAM,IAAI,UAAA,CAAW,KAAK,CAAA;AAChC,EAAA,KAAA,IAAS,CAAA,GAAI,CAAA,EAAG,CAAA,GAAI,MAAA,CAAO,QAAQ,CAAA,EAAA,EAAK;AACpC,IAAA,GAAA,CAAI,GAAA,CAAI,IAAI,UAAA,CAAW,MAAA,CAAO,CAAC,CAAE,CAAA,EAAG,OAAA,CAAQ,CAAC,CAAE,CAAA;AAAA,EACnD;AAEA,EAAA,KAAA,MAAW,EAAA,IAAM,IAAA,CAAK,WAAA,IAAe,EAAC,EAAG;AACrC,IAAA,EAAA,CAAG,cAAc,EAAA,CAAG,UAAA,IAAc,KAAK,OAAA,CAAQ,EAAA,CAAG,UAAU,CAAC,CAAA;AAC7D,IAAA,EAAA,CAAG,MAAA,GAAS,CAAA;AAAA,EAChB;AAEA,EAAA,OAAO,IAAI,QAAA,CAAS,GAAA,CAAI,MAAM,CAAA;AAClC;AAEA,SAAS,gBAAA,CAAiB,KAAa,OAAA,EAAyB;AAC5D,EAAA,IAAI,OAAA,EAAS;AACT,IAAA,OAAO,IAAI,GAAA,CAAI,GAAA,EAAK,OAAA,GAAU,GAAG,CAAA,CAAE,IAAA;AAAA,EACvC;AACA,EAAA,IAAI;AACA,IAAA,OAAO,IAAI,GAAA,CAAI,GAAG,CAAA,CAAE,IAAA;AAAA,EACxB,CAAA,CAAA,MAAQ;AACJ,IAAA,MAAM,IAAI,MAAM,iDAAiD,CAAA;AAAA,EACrE;AACJ;;;;"}