{"version":3,"file":"morph-targets.js","sources":["../../../../../src/material/node/blocks/morph-targets.ts"],"sourcesContent":["/** MorphTargetsBlock — applies per-target position/normal deltas sampled\n *  from the morph-atlas texture.\n *\n *  Inputs:  position (vec3), normal (vec3), tangent (vec4), uv (vec2).\n *  Outputs: positionOutput, normalOutput, tangentOutput, uvOutput.\n *\n *  Only position and normal are currently wired to a real morph accumulation;\n *  tangent/uv/uv2 are pass-through (Lite's morph atlas carries only pos/norm\n *  deltas — see morph/create-morph-targets.ts). If a graph consumes\n *  tangentOutput/uvOutput we simply return the base input.\n *\n *  The block sets `state.usesMorphTargets`; node-pipeline.ts adds the\n *  `morphTargets` texture + `morph` UBO bindings, emits the struct +\n *  helper functions at module scope, and wires `@builtin(vertex_index)`\n *  through as `vertexIndex` so the helpers can locate this vertex's row.\n */\n\nimport type { BlockEmitter, NodeExpr, NodeValueType } from \"../node-types.js\";\n\nconst PASSTHROUGH_KINDS = new Set([\"tangent\", \"uv\", \"uv2\"]);\n\nexport const emitter: BlockEmitter = {\n    className: \"MorphTargetsBlock\",\n    stage: \"vertex\",\n    emit(block, outputName, stage, state, ctx) {\n        state.usesMorphTargets = true;\n        const kind = outputName.replace(/Output$/, \"\"); // position | normal | tangent | uv\n        const input = block.inputs.get(kind);\n        if (!input?.source) {\n            return fallback(kind);\n        }\n        const v = ctx.resolve(block, kind, stage, state);\n        if (kind === \"position\") {\n            const base = ctx.cast(v, \"vec3f\").expr;\n            return { expr: `nme_morphPosition(${base}, vertexIndex)`, type: \"vec3f\" };\n        }\n        if (kind === \"normal\") {\n            const base = ctx.cast(v, \"vec3f\").expr;\n            return { expr: `nme_morphNormal(${base}, vertexIndex)`, type: \"vec3f\" };\n        }\n        // Tangent/uv/uv2 — no delta bands stored; pass through.\n        if (PASSTHROUGH_KINDS.has(kind)) {\n            return v;\n        }\n        return v;\n    },\n};\n\nfunction fallback(kind: string): NodeExpr {\n    const type: NodeValueType = kind === \"uv\" || kind === \"uv2\" ? \"vec2f\" : kind === \"tangent\" ? \"vec4f\" : \"vec3f\";\n    const zero = type === \"vec2f\" ? \"vec2<f32>(0.0)\" : type === \"vec4f\" ? \"vec4<f32>(0.0)\" : \"vec3<f32>(0.0)\";\n    return { expr: zero, type };\n}\n"],"names":[],"mappings":"AAmBA,MAAM,oCAAoB,IAAI,GAAA,CAAI,CAAC,SAAA,EAAW,IAAA,EAAM,KAAK,CAAC,CAAA;AAEnD,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,mBAAA;AAAA,EACX,KAAA,EAAO,QAAA;AAAA,EACP,IAAA,CAAK,KAAA,EAAO,UAAA,EAAY,KAAA,EAAO,OAAO,GAAA,EAAK;AACvC,IAAA,KAAA,CAAM,gBAAA,GAAmB,IAAA;AACzB,IAAA,MAAM,IAAA,GAAO,UAAA,CAAW,OAAA,CAAQ,SAAA,EAAW,EAAE,CAAA;AAC7C,IAAA,MAAM,KAAA,GAAQ,KAAA,CAAM,MAAA,CAAO,GAAA,CAAI,IAAI,CAAA;AACnC,IAAA,IAAI,CAAC,OAAO,MAAA,EAAQ;AAChB,MAAA,OAAO,SAAS,IAAI,CAAA;AAAA,IACxB;AACA,IAAA,MAAM,IAAI,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,IAAA,EAAM,OAAO,KAAK,CAAA;AAC/C,IAAA,IAAI,SAAS,UAAA,EAAY;AACrB,MAAA,MAAM,IAAA,GAAO,GAAA,CAAI,IAAA,CAAK,CAAA,EAAG,OAAO,CAAA,CAAE,IAAA;AAClC,MAAA,OAAO,EAAE,IAAA,EAAM,CAAA,kBAAA,EAAqB,IAAI,CAAA,cAAA,CAAA,EAAkB,MAAM,OAAA,EAAQ;AAAA,IAC5E;AACA,IAAA,IAAI,SAAS,QAAA,EAAU;AACnB,MAAA,MAAM,IAAA,GAAO,GAAA,CAAI,IAAA,CAAK,CAAA,EAAG,OAAO,CAAA,CAAE,IAAA;AAClC,MAAA,OAAO,EAAE,IAAA,EAAM,CAAA,gBAAA,EAAmB,IAAI,CAAA,cAAA,CAAA,EAAkB,MAAM,OAAA,EAAQ;AAAA,IAC1E;AAEA,IAAA,IAAI,iBAAA,CAAkB,GAAA,CAAI,IAAI,CAAA,EAAG;AAC7B,MAAA,OAAO,CAAA;AAAA,IACX;AACA,IAAA,OAAO,CAAA;AAAA,EACX;AACJ;AAEA,SAAS,SAAS,IAAA,EAAwB;AACtC,EAAA,MAAM,IAAA,GAAsB,SAAS,IAAA,IAAQ,IAAA,KAAS,QAAQ,OAAA,GAAU,IAAA,KAAS,YAAY,OAAA,GAAU,OAAA;AACvG,EAAA,MAAM,OAAO,IAAA,KAAS,OAAA,GAAU,gBAAA,GAAmB,IAAA,KAAS,UAAU,gBAAA,GAAmB,gBAAA;AACzF,EAAA,OAAO,EAAE,IAAA,EAAM,IAAA,EAAM,IAAA,EAAK;AAC9B;;;;"}