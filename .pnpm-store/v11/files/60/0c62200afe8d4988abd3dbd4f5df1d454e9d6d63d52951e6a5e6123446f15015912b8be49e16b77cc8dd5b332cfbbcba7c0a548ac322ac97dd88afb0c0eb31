{"version":3,"sources":["../../../../../packages/react-resize-handle/src/hooks/useKeyboardHandler.ts"],"sourcesContent":["import { useEventCallback, useFluent } from '@fluentui/react-components';\nimport type { EventHandler } from '@fluentui/react-utilities';\nimport * as React from 'react';\n\nimport {\n  EVENTS,\n  GrowDirection,\n  ResizeHandleUpdateEventData,\n  SupportedKeys,\n} from '../types';\nimport type { UnitHandle } from './useUnitHandle';\n\nexport type UseKeyboardHandlerOptions = {\n  onValueChange: EventHandler<ResizeHandleUpdateEventData>;\n  growDirection: GrowDirection;\n\n  getCurrentValue: () => number;\n  unitHandle: UnitHandle;\n};\n\nconst multipliers: Record<\n  GrowDirection,\n  Partial<Record<SupportedKeys, number>>\n> = {\n  end: {\n    ArrowRight: 1,\n    ArrowLeft: -1,\n  },\n  start: {\n    ArrowRight: -1,\n    ArrowLeft: 1,\n  },\n  up: {\n    ArrowUp: 1,\n    ArrowDown: -1,\n  },\n  down: {\n    ArrowUp: -1,\n    ArrowDown: 1,\n  },\n};\n\nfunction isSupportedKey(\n  growDirection: GrowDirection,\n  key: string\n): key is SupportedKeys {\n  return (\n    Object.prototype.hasOwnProperty.call(multipliers, growDirection) &&\n    Object.prototype.hasOwnProperty.call(multipliers[growDirection], key)\n  );\n}\n\nexport const useKeyboardHandler = (\n  options: UseKeyboardHandlerOptions\n): {\n  attachHandlers: (node: HTMLElement) => void;\n  detachHandlers: (node: HTMLElement) => void;\n} => {\n  const { onValueChange, growDirection, getCurrentValue, unitHandle } = options;\n  const { dir } = useFluent();\n\n  const onKeyDown = useEventCallback((event: KeyboardEvent) => {\n    if (!isSupportedKey(growDirection, event.key)) {\n      return;\n    }\n\n    const currentValue = getCurrentValue();\n\n    const multiplier = multipliers[growDirection][event.key] ?? 1;\n    const directionMultiplier =\n      dir === 'rtl' && ['start', 'end'].includes(growDirection) ? -1 : 1;\n    const offset =\n      multiplier * unitHandle.getOffsetStep() * directionMultiplier;\n\n    onValueChange(event, {\n      event,\n      value: unitHandle.roundValue(currentValue + offset),\n      type: EVENTS.keyboard,\n      unit: unitHandle.name,\n    });\n  });\n\n  const attachHandlers = React.useCallback(\n    (node: HTMLElement) => {\n      node.addEventListener('keydown', onKeyDown);\n    },\n    [onKeyDown]\n  );\n\n  const detachHandlers = React.useCallback(\n    (node: HTMLElement) => {\n      node.removeEventListener('keydown', onKeyDown);\n    },\n    [onKeyDown]\n  );\n\n  return {\n    attachHandlers,\n    detachHandlers,\n  };\n};\n"],"names":["useEventCallback","useFluent","React","EVENTS","multipliers","end","ArrowRight","ArrowLeft","start","up","ArrowUp","ArrowDown","down","isSupportedKey","growDirection","key","Object","prototype","hasOwnProperty","call","useKeyboardHandler","options","onValueChange","getCurrentValue","unitHandle","dir","onKeyDown","event","currentValue","multiplier","directionMultiplier","includes","offset","getOffsetStep","value","roundValue","type","keyboard","unit","name","attachHandlers","useCallback","node","addEventListener","detachHandlers","removeEventListener"],"mappings":"AAAA,SAASA,gBAAgB,EAAEC,SAAS,QAAQ,6BAA6B;AAEzE,YAAYC,WAAW,QAAQ;AAE/B,SACEC,MAAM,QAID,WAAW;AAWlB,MAAMC,cAGF;IACFC,KAAK;QACHC,YAAY;QACZC,WAAW,CAAC;IACd;IACAC,OAAO;QACLF,YAAY,CAAC;QACbC,WAAW;IACb;IACAE,IAAI;QACFC,SAAS;QACTC,WAAW,CAAC;IACd;IACAC,MAAM;QACJF,SAAS,CAAC;QACVC,WAAW;IACb;AACF;AAEA,SAASE,eACPC,aAA4B,EAC5BC,GAAW;IAEX,OACEC,OAAOC,SAAS,CAACC,cAAc,CAACC,IAAI,CAACf,aAAaU,kBAClDE,OAAOC,SAAS,CAACC,cAAc,CAACC,IAAI,CAACf,WAAW,CAACU,cAAc,EAAEC;AAErE;AAEA,OAAO,MAAMK,qBAAqB,CAChCC;IAKA,MAAM,EAAEC,aAAa,EAAER,aAAa,EAAES,eAAe,EAAEC,UAAU,EAAE,GAAGH;IACtE,MAAM,EAAEI,GAAG,EAAE,GAAGxB;IAEhB,MAAMyB,YAAY1B,iBAAiB,CAAC2B;QAClC,IAAI,CAACd,eAAeC,eAAea,MAAMZ,GAAG,GAAG;YAC7C;QACF;QAEA,MAAMa,eAAeL;YAEFnB;QAAnB,MAAMyB,aAAazB,CAAAA,uCAAAA,WAAW,CAACU,cAAc,CAACa,MAAMZ,GAAG,CAAC,YAArCX,uCAAyC;QAC5D,MAAM0B,sBACJL,QAAQ,SAAS;YAAC;YAAS;SAAM,CAACM,QAA