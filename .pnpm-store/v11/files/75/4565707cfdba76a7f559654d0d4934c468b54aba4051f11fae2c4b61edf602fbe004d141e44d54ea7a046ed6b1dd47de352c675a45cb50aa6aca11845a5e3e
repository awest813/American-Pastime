{"version":3,"file":"transform-block.js","sources":["../../../../../src/material/node/blocks/transform-block.ts"],"sourcesContent":["/** TransformBlock — matrix * vector.\n *\n *  BJS serializes `complementW` (default 1.0 for positions, 0.0 for directions)\n *  and `complementZ` for 2D-vector → 3D promotion. We honour both.\n */\n\nimport type { BlockEmitter } from \"../node-types.js\";\nimport { formatFloat } from \"./_math-factory.js\";\n\nexport const emitter: BlockEmitter = {\n    className: \"TransformBlock\",\n    stage: \"vertex\",\n    emit(block, _outputName, stage, state, ctx) {\n        const vector = ctx.resolve(block, \"vector\", stage, state);\n        const transform = ctx.resolve(block, \"transform\", stage, state);\n        const wRaw = block.serialized.complementW;\n        const zRaw = block.serialized.complementZ;\n        const cw = formatFloat(typeof wRaw === \"number\" ? wRaw : 1);\n        const cz = formatFloat(typeof zRaw === \"number\" ? zRaw : 0);\n\n        let vec4: string;\n        switch (vector.type) {\n            case \"vec4f\":\n                vec4 = vector.expr;\n                break;\n            case \"vec3f\":\n                vec4 = `vec4<f32>(${vector.expr}, ${cw})`;\n                break;\n            case \"vec2f\":\n                vec4 = `vec4<f32>(${vector.expr}, ${cz}, ${cw})`;\n                break;\n            default:\n                vec4 = `vec4<f32>(${ctx.cast(vector, \"vec3f\").expr}, ${cw})`;\n        }\n        return { expr: `(${transform.expr} * ${vec4})`, type: \"vec4f\" };\n    },\n};\n"],"names":[],"mappings":";;AASO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,gBAAA;AAAA,EACX,KAAA,EAAO,QAAA;AAAA,EACP,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,SAAS,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,QAAA,EAAU,OAAO,KAAK,CAAA;AACxD,IAAA,MAAM,YAAY,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,WAAA,EAAa,OAAO,KAAK,CAAA;AAC9D,IAAA,MAAM,IAAA,GAAO,MAAM,UAAA,CAAW,WAAA;AAC9B,IAAA,MAAM,IAAA,GAAO,MAAM,UAAA,CAAW,WAAA;AAC9B,IAAA,MA