{"version":3,"file":"unlit-fragment.js","sources":["../../../../../src/material/pbr/fragments/unlit-fragment.ts"],"sourcesContent":["/**\n * Unlit Fragment (KHR_materials_unlit).\n *\n * Replaces the lit-color computation with `baseColor * unlitColor` right\n * before the tonemap/gamma/contrast chain runs.  Depends on the IBL fragment\n * when present so our AI injection runs *after* IBL's, overwriting the IBL\n * color contribution.  The subsequent tonemap/gamma/contrast stages still\n * apply, matching BJS's unlit output under `createDefaultEnvironment`.\n *\n * Zero bytes in bundles for scenes that don't use unlit materials.\n */\n\nimport type { ShaderFragment } from \"../../../shader/fragment-types.js\";\nimport type { PbrMaterialProps } from \"../pbr-material.js\";\nimport type { PbrExt } from \"../pbr-flags.js\";\nimport { PBR2_HAS_UNLIT } from \"../pbr-flag-bits.js\";\n\nexport function createUnlitFragment(hasIbl: boolean): ShaderFragment {\n    const assign = `color = baseColor * material.unlitColor;`;\n    return {\n        _id: \"unlit\",\n        _dependencies: hasIbl ? [\"ibl\"] : undefined,\n        _uboFields: [\n            { _name: \"unlitColor\", _type: \"vec3<f32>\" },\n            { _name: \"_unlitColorPad\", _type: \"f32\" },\n        ],\n        _fragmentSlots: hasIbl ? { AI: assign } : { NI: assign },\n    };\n}\n\n/** Write the unlit material-UBO slice. */\nexport function writeUnlitUBO(data: Float32Array, material: PbrMaterialProps, offsets: ReadonlyMap<string, number>): void {\n    if (!material.unlit || !offsets.has(\"unlitColor\")) {\n        return;\n    }\n    const off = offsets.get(\"unlitColor\")! / 4;\n    const tint = material.unlitColor ?? [1, 1, 1];\n    data[off] = tint[0]!;\n    data[off + 1] = tint[1]!;\n    data[off + 2] = tint[2]!;\n}\n\nexport const pbrExt: PbrExt = {\n    id: \"unlit\",\n    phase: \"fragment\",\n    detect(mat) {\n        return (mat as PbrMaterialProps).unlit ? { f: 0, f2: PBR2_HAS_UNLIT } : { f: 0, f2: 0 };\n    },\n    frag(ctx) {\n        if (!(ctx._features2 & PBR2_HAS_UNLIT)) {\n            return null;\n        }\n        return createUnlitFragment(ctx._hasIbl);\n    },\n    writeUbo: writeUnlitUBO as PbrExt[\"writeUbo\"],\n};\n"],"names":[],"mappings":";;AAiBO,SAAS,oBAAoB,MAAA,EAAiC;AACjE,EAAA,MAAM,MAAA,GAAS,CAAA,wCAAA,CAAA;AACf,EAAA,OAAO;AAAA,IACH,GAAA,EAAK,OAAA;AAAA,IACL,aAAA,EAAe,MAAA,GAAS,CAAC,KAAK,CAAA,GAAI,MAAA;AAAA,IAClC,UAAA,EAAY;AAAA,MACR,EAAE,KAAA,EAAO,YAAA,EAAc,KAAA,EAAO,WAAA,EAAY;AAAA,MAC1C,EAAE,KAAA,EAAO,gBAAA,EAAkB,KAAA,EAAO,KAAA;AAAM,KAC5C;AAAA,IACA,cAAA,EAAgB,SAAS,EAAE,EAAA,EAAI,QAAO,GAAI,EAAE,IAAI,MAAA;AAAO,GAC3D;AACJ;AAGO,SAAS,aAAA,CAAc,IAAA,EAAoB,QAAA,EAA4B,OAAA,EAA4C;AACtH,EAAA,IAAI,CAAC,QAAA,CAAS,KAAA,IAAS,CAAC,OAAA,CAAQ,GAAA,CAAI,YAAY,CAAA,EAAG;AAC/C,IAAA;AAAA,EACJ;AACA,EAAA,MAAM,GAAA,GAAM,OAAA,CAAQ,GAAA,CAAI,YAAY,CAAA,GAAK,CAAA;AACzC,EAAA,MAAM,OAAO,QAAA,CAAS,UAAA,IAAc,CAAC,CAAA,EAAG,GAAG,CAAC,CAAA;AAC5C,EAAA,IAAA,CAAK,GAAG,CAAA,GAAI,IAAA,CAAK,CAAC,CAAA;AAClB,EAAA,IAAA,CAAK,GAAA,GAAM,CAAC,CAAA,GAAI,IAAA,CAAK,CAAC,CAAA;AACtB,EAAA,IAAA,CAAK,GAAA,GAAM,CAAC,CAAA,GAAI,IAAA,CAAK,CAAC,CAAA;AAC1B;AAEO,MAAM,MAAA,GAAiB;AAAA,EAC1B,EAAA,EAAI,OAAA;AAAA,EACJ,KAAA,EAAO,UAAA;AAAA,EACP,OAAO,GAAA,EAAK;AACR,IAAA,OAAQ,GAAA,CAAyB,KAAA,GAAQ,EAAE,CAAA,EAAG,CAAA,EAAG,EAAA,EAAI,cAAA,EAAe,GAAI,EAAE,CAAA,EAAG,CAAA,EAAG,EAAA,EAAI,CAAA,EAAE;AAAA,EAC1F,CAAA;AAAA,EACA,KAAK,GAAA,EAAK;AACN,IAAA,IAAI,EAAE,GAAA,CAAI,UAAA,GAAa,cAAA,CAAA,EAAiB;AACpC,MAAA,OAAO,IAAA;AAAA,IACX;AACA,IAAA,OAAO,mBAAA,CAAoB,IAAI,OAAO,CAAA;AAAA,EAC1C,CAAA;AAAA,EACA,QAAA,EAAU;AACd;;;;"}