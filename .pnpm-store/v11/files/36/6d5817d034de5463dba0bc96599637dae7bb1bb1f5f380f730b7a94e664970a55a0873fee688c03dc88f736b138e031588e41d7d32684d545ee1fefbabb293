{"version":3,"file":"reciprocal-block.js","sources":["../../../../../src/material/node/blocks/reciprocal-block.ts"],"sourcesContent":["import type { BlockEmitter } from \"../node-types.js\";\n\nexport const emitter: BlockEmitter = {\n    className: \"ReciprocalBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const input = ctx.resolve(block, \"input\", stage, state);\n        if (input.type === \"mat4f\") {\n            return { expr: `inverse(${input.expr})`, type: \"mat4f\" };\n        }\n        return { expr: `(1.0 / ${input.expr})`, type: input.type };\n    },\n};\n"],"names":[],"mappings":"AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,iBAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,QAAQ,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,OAAO,KAAK,CAAA;AACtD,IAAA,IAAI,KAAA,CAAM,SAAS,OAAA,EAAS;AACxB,MAAA,OAAO,EAAE,IAAA,EAAM,CAAA,QAAA,EAAW,MAAM,IAAI,CAAA,CAAA,CAAA,EAAK,MAAM,OAAA,EAAQ;AAAA,IAC3D;AACA,IAAA,OAAO,EAAE,MAAM,CAAA,OAAA,EAAU,KAAA,CAAM,IAAI,CAAA,CAAA,CAAA,EAAK,IAAA,EAAM,MAAM,IAAA,EAAK;AAAA,EAC7D;AACJ;;;;"}