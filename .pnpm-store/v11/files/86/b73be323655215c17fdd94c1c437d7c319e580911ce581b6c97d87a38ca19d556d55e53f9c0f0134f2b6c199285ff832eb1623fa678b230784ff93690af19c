{"version":3,"file":"fresnel-block.js","sources":["../../../../../src/material/node/blocks/fresnel-block.ts"],"sourcesContent":["import type { BlockEmitter } from \"../node-types.js\";\n\nconst HELPER = `fn nme_computeFresnelTerm(viewDirection: vec3<f32>, worldNormal: vec3<f32>, bias: f32, power: f32) -> f32 {\n    let fresnelTerm = pow(bias + abs(dot(viewDirection, worldNormal)), power);\n    return clamp(fresnelTerm, 0.0, 1.0);\n}`;\n\nexport const emitter: BlockEmitter = {\n    className: \"FresnelBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const worldNormal = ctx.cast(ctx.resolve(block, \"worldNormal\", stage, state), \"vec3f\").expr;\n        const viewDirection = ctx.cast(ctx.resolve(block, \"viewDirection\", stage, state), \"vec3f\").expr;\n        const bias = ctx.cast(ctx.resolve(block, \"bias\", stage, state), \"f32\").expr;\n        const power = ctx.cast(ctx.resolve(block, \"power\", stage, state), \"f32\").expr;\n        const stageState = stage === \"vertex\" ? state.vertex : state.fragment;\n        stageState.helpers.set(\"nme_computeFresnelTerm\", HELPER);\n        return { expr: `nme_computeFresnelTerm(${viewDirection}, ${worldNormal}, ${bias}, ${power})`, type: \"f32\" };\n    },\n};\n"],"names":[],"mappings":"AAEA,MAAM,MAAA,GAAS,CAAA;AAAA;AAAA;AAAA,CAAA,CAAA;AAKR,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,cAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,WAAA,GAAc,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,aAAA,EAAe,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA,CAAE,IAAA;AACvF,IAAA,MAAM,aAAA,GAAgB,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,eAAA,EAAiB,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA,CAAE,IAAA;AAC3F,IAAA,MAAM,IAAA,GAAO,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,MAAA,EAAQ,KAAA,EAAO,KAAK,CAAA,EAAG,KAAK,CAAA,CAAE,IAAA;AACvE,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,KAAA,EAAO,OAAA,EAAS,KAAA,EAAO,KAAK,CAAA,EAAG,KAAK,CAAA,CAAE,IAAA;AACzE,IAAA,MAAM,UAAA,GAAa,KAAA,KAAU,QA