{"version":3,"file":"storage-read-block.js","sources":["../../../../../src/material/node/blocks/storage-read-block.ts"],"sourcesContent":["import type { BlockEmitter, Stage } from \"../node-types.js\";\n\nfunction loopKey(stage: Stage, blockId: number): string {\n    return `${stage}|${blockId}`;\n}\n\nexport const emitter: BlockEmitter = {\n    className: \"StorageReadBlock\",\n    emit(block, outputName, stage, state, _ctx) {\n        if (outputName !== \"value\") {\n            throw new Error(`StorageReadBlock \"${block.name}\": unsupported output \"${outputName}\"`);\n        }\n        const loopSource = block.inputs.get(\"loopID\")?.source;\n        if (!loopSource) {\n            throw new Error(`StorageReadBlock \"${block.name}\": loopID input is not connected`);\n        }\n        const active = state.loopVariables.get(loopKey(stage, loopSource.blockId));\n        if (!active) {\n            throw new Error(`StorageReadBlock \"${block.name}\": loop ${loopSource.blockId} is not active`);\n        }\n        return { expr: active.valueVar, type: active.valueType };\n    },\n};\n"],"names":[],"mappings":"AAEA,SAAS,OAAA,CAAQ,OAAc,OAAA,EAAyB;AACpD,EAAA,OAAO,CAAA,EAAG,KAAK,CAAA,CAAA,EAAI,OAAO,CAAA,CAAA;AAC9B;AAEO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,kBAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,UAAA,EAAY,KAAA,EAAO,OAAO,IAAA,EAAM;AACxC,IAAA,IAAI,eAAe,OAAA,EAAS;AACxB,MAAA,MAAM,IAAI,KAAA,CAAM,CAAA,kBAAA,EAAqB,MAAM,IAAI,CAAA,uBAAA,EAA0B,UAAU,CAAA,CAAA,CAAG,CAAA;AAAA,IAC1F;AACA,IAAA,MAAM,UAAA,GAAa,KAAA,CAAM,MAAA,CAAO,GAAA,CAAI,QAAQ,CAAA,EAAG,MAAA;AAC/C,IAAA,IAAI,CAAC,UAAA,EAAY;AACb,MAAA,MAAM,IAAI,KAAA,CAAM,CAAA,kBAAA,EAAqB,KAAA,CAAM,IAAI,CAAA,gCAAA,CAAkC,CAAA;AAAA,IACrF;AACA,IAAA,MAAM,MAAA,GAAS,MAAM,aAAA,CAAc,GAAA,CAAI,QAAQ,KAAA,EAAO,UAAA,CAAW,OAAO,CAAC,CAAA;AACzE,IAAA,IAAI,CAAC,MAAA,EAAQ;AACT,MAAA,MAAM,IAAI,MAAM,CAAA,kBAAA,EAAqB,KAAA,CAAM,IAAI,CAAA,QAAA,EAAW,UAAA,CAAW,OAAO,CAAA,cAAA,CAAgB,CAAA;AAAA,IAChG;AACA,IAAA,OAAO,EAAE,IAAA,EAAM,MAAA,CAAO,QAAA,EAAU,IAAA,EAAM,OAAO,SAAA,E