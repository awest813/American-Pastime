{"version":3,"file":"rotate2d-block.js","sources":["../../../../../src/material/node/blocks/rotate2d-block.ts"],"sourcesContent":["/** Rotate2dBlock — rotates a vec2 by angle radians around the origin. */\n\nimport type { BlockEmitter } from \"../node-types.js\";\n\nexport const emitter: BlockEmitter = {\n    className: \"Rotate2dBlock\",\n    emit(block, _outputName, stage, state, ctx) {\n        const input = ctx.cast(ctx.resolve(block, \"input\", stage, state), \"vec2f\");\n        const angle = ctx.cast(ctx.resolve(block, \"angle\", stage, state), \"f32\");\n        return {\n            expr: `vec2<f32>(cos(${angle.expr}) * (${input.expr}).x - sin(${angle.expr}) * (${input.expr}).y, sin(${angle.expr}) * (${input.expr}).x + cos(${angle.expr}) * (${input.expr}).y)`,\n            type: \"vec2f\",\n        };\n    },\n};\n"],"names":[],"mappings":"AAIO,MAAM,OAAA,GAAwB;AAAA,EACjC,SAAA,EAAW,eAAA;AAAA,EACX,IAAA,CAAK,KAAA,EAAO,WAAA,EAAa,KAAA,EAAO,OAAO,GAAA,EAAK;AACxC,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,OAAO,OAAA,EAAS,KAAA,EAAO,KAAK,CAAA,EAAG,OAAO,CAAA;AACzE,IAAA,MAAM,KAAA,GAAQ,GAAA,CAAI,IAAA,CAAK,GAAA,CAAI,OAAA,CAAQ,OAAO,OAAA,EAAS,KAAA,EAAO,KAAK,CAAA,EAAG,KAAK,CAAA;AACvE,IAAA,OAAO;AAAA,MACH,IAAA,EAAM,CAAA,cAAA,EAAiB,KAAA,CAAM,IAAI,CAAA,KAAA,EAAQ,MAAM,IAAI,CAAA,UAAA,EAAa,KAAA,CAAM,IAAI,CAAA,KAAA,EAAQ,KAAA,CAAM,IAAI,CAAA,SAAA,EAAY,KAAA,CAAM,IAAI,CAAA,KAAA,EAAQ,KAAA,CAAM,IAAI,aAAa,KAAA,CAAM,IAAI,CAAA,KAAA,EAAQ,KAAA,CAAM,IAAI,CAAA,IAAA,CAAA;AAAA,MAC7K,IAAA,EAAM;AAAA,KACV;AAAA,EACJ;AACJ;;;;"}